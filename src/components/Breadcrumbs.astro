---
interface Props {
  items: { name: string; href: string }[];
}
const { items } = Astro.props;
---
{items.length > 1 && (
  <nav class="crumbs" aria-label="Okruszki nawigacyjne">
    <ol class="crumbs-list">
      {items.map((item, i) => (
        <li class="crumbs-item">
          {i < items.length - 1 ? (
            <>
              <a href={item.href}>{item.name}</a>
              <span class="crumbs-sep" aria-hidden="true">›</span>
            </>
          ) : (
            <span aria-current="page">{item.name}</span>
          )}
        </li>
      ))}
    </ol>
  </nav>
)}

<style is:global>
  .crumbs {
    background: var(--cream);
    padding: 12px 6% 0;
  }
  .crumbs-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 0 auto;
    padding: 0;
    max-width: 1200px;
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.5px;
  }
  .crumbs-item { display: flex; align-items: center; gap: 6px; }
  .crumbs-item a { color: var(--coral); text-decoration: none; }
  .crumbs-item a:hover { text-decoration: underline; }
  .crumbs-item span[aria-current] { color: var(--dark); opacity: 0.6; }
  .crumbs-sep { color: var(--dark); opacity: 0.35; }
</style>
