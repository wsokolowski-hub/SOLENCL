---
import { site } from '@/data/site';

interface Props {
  pageType?: 'home' | 'service' | 'contact' | 'faq' | 'about' | 'location';
  faq?: { q: string; a: string }[];
  breadcrumbs?: { name: string; href: string }[];
}
const { pageType = 'home', faq, breadcrumbs } = Astro.props;

const business = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'SportsActivityLocation'],
  '@id': `${site.url}/#business`,
  name: site.name,
  description: site.description,
  url: site.url,
  telephone: [site.phone, site.phone2],
  email: site.email,
  image: `${site.url}/assets/logo-kwadrat.webp`,
  logo: `${site.url}/assets/logo.png`,
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    postalCode: site.address.postal,
    addressCountry: site.country,
  },
  geo: { '@type': 'GeoCoordinates', latitude: site.geo.lat, longitude: site.geo.lng },
  areaServed: { '@type': 'City', name: site.city },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: site.rating.value,
    reviewCount: site.rating.count,
    bestRating: '5',
  },
  priceRange: site.priceRange,
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Saturday', opens: '09:00', closes: '15:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Sunday',   opens: '09:00', closes: '12:00' },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Kursy pływania',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'Pływanie niemowląt i dzieci do lat 4', description: 'Zajęcia rodzic+dziecko, 30 min, grupy do 10 par.' },
        price: '55', priceCurrency: 'PLN',
      },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'Nauka pływania dla dzieci od podstaw (5–10 lat)', description: 'Zajęcia 45 min, grupy do 10 dzieci.' },
        price: '65', priceCurrency: 'PLN',
      },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'Doskonalenie pływania dla dzieci (5–10 lat)', description: 'Zajęcia 45 min, grupy do 10 dzieci, soboty i niedziele.' },
        price: '65', priceCurrency: 'PLN',
      },
    ],
  },
  sameAs: [site.social.facebook, site.social.instagram],
};

const breadcrumbList = breadcrumbs && breadcrumbs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((b, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: b.name,
    item: new URL(b.href, site.url).toString(),
  })),
} : null;

const faqPage = faq && faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((q) => ({
    '@type': 'Question',
    name: q.q,
    acceptedAnswer: { '@type': 'Answer', text: q.a },
  })),
} : null;
---
<script type="application/ld+json" set:html={JSON.stringify(business)} />
{breadcrumbList && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbList)} />}
{faqPage && <script type="application/ld+json" set:html={JSON.stringify(faqPage)} />}
