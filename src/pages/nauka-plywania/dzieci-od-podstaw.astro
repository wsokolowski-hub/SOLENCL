  path="/nauka-plywania/dzieci-od-podstaw/"
  eyebrow="Dzieci od podstaw"
  h1={`Nauka pływania dla dzieci<br/><span>od podstaw — Wrocław</span>`}
  slogan="Pierwsze samodzielne tempo na wodzie"
  lead="Zajęcia dla dzieci 5–10 lat, które dopiero zaczynają przygodę z pływaniem — w soboty i niedziele. Dziecko ćwiczy samodzielnie pod okiem instruktora — uczymy podstaw, oddechu oraz stylów: kraula, grzbietu i żabki."
  serviceName="Nauka pływania dla dzieci od podstaw"
  price="65"
  priceUnit="zł / 45 min"
  ageRange="5 – 10 lat"
  groupSize="max 8 dzieci"
