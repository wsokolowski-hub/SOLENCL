---
import Base from '@/layouts/Base.astro';
import { site } from '@/data/site';
const title = 'Szkoła Pływania dla Dzieci Wrocław — weekendy | Solen Swim';
const description = 'Szkoła pływania dla dzieci we Wrocławiu (Grabiszyn). Zajęcia w weekendy od 6. miesiąca do 10 lat. Małe grupy do 8 osób, certyfikowani instruktorzy.';

// Opinie Google (Featurable API) — pobierane w czasie builda; przy braku
// dostępu do sieci sekcja renderuje się bez statycznych opinii (fallback).
type StaticReview = { author: string; text: string };
let staticReviews: StaticReview[] = [];
try {
  const res = await fetch(
    `https://featurable.com/api/v1/widgets/${site.reviews.featurableWidgetId}`,
    { signal: AbortSignal.timeout(8000) },
  );
  if (res.ok) {
    const data: any = await res.json();
    staticReviews = (data?.reviews ?? [])
      .filter((r: any) => (r?.comment || r?.text) && ['FIVE', 5].includes(r?.starRating ?? r?.rating))
      .slice(0, 3)
      .map((r: any) => ({
        author: String(r?.reviewer?.displayName ?? r?.author ?? 'Klient Google'),
        text: String(r?.comment ?? r?.text ?? '').slice(0, 260),
      }));
  }
} catch {
  // brak sieci podczas builda — pomijamy statyczne opinie
}
const path = '/';
const pageType = 'home' as const;
const breadcrumbs = [];
---
<Base title={title} description={description} path={path} pageType={pageType} breadcrumbs={breadcrumbs}>
<!-- ===== HERO ===== -->
<section class="hero">
  <div class="hero-left"></div>
  <div class="hero-right">
    <p class="hero-eyebrow">Solen Swim · Grabiszyn · soboty i niedziele</p>
    <h1 class="hero-h1">Szkoła pływania dla dzieci<br>we Wrocławiu</h1>
    <p class="hero-desc">Zacznij pływać z <strong>Solen Swim!</strong> Zajęcia w weekendy na basenie przy ul. Ostrowskiego 3 — od 6. miesiąca do 10 lat. Uczymy przez zabawę, w grupach do 8 osób.</p>
    <a class="hero-cta" href="/zapisy/">Zapisz się</a>
  </div>
  <img class="hero-goggles" src="/assets/okularki.webp" alt="Okularki pływackie Solen Swim" width="1060" height="1060">
</section>
<!-- ===== KURSY ===== -->
<section class="kursy">

  <h2 class="kursy-title">Nasze kursy</h2>

  <!-- KURS 1 -->
  <a class="kurs" href="/nauka-plywania/niemowleta-i-dzieci-do-4-lat/">
    <div class="kurs-foto">
      <img src="/assets/img-924d79bd96e8.webp" alt="Pływanie niemowląt i dzieci do lat 4" width="800" height="661" loading="lazy">
    </div>
    <div class="kurs-info">
      <h3 class="kurs-nazwa">Pływanie niemowląt<br>i dzieci do lat 4</h3>
      <div class="kurs-szczegoly">
        Sobota 9:00 – 15:00<br>
        Niedziela 9:00 – 12:00<br>
        <span class="kurs-wyroznienie">Rodzic uczestniczy razem z dzieckiem</span><br>
        Czas trwania: 30 minut<br>
        ul. Ostrowskiego 3, Wrocław Grabiszyn
      </div>
      <span class="kurs-link">Pływanie niemowląt — szczegóły →</span>
    </div>
  </a>

  <!-- KURS 2 — odwrócony -->
  <a class="kurs odwrocony" href="/nauka-plywania/dzieci-od-podstaw/">
    <div class="kurs-foto">
      <img src="/assets/img-20f0624ea60b.webp" alt="Nauka pływania dla dzieci od podstaw" width="800" height="620" loading="lazy">
    </div>
    <div class="kurs-info">
      <h3 class="kurs-nazwa">Nauka pływania dla<br>dzieci od podstaw</h3>
      <div class="kurs-szczegoly">
        <span class="label">Zajęcia:</span>
        Sobota 9:00 – 15:00<br>
        Niedziela 9:00 – 12:00<br>
        Czas trwania: 45 minut<br>
        ul. Ostrowskiego 3, Wrocław Grabiszyn
      </div>
      <span class="kurs-link">Nauka pływania od podstaw — szczegóły →</span>
    </div>
  </a>

  <!-- KURS 3 -->
  <a class="kurs" href="/nauka-plywania/doskonalenie/">
    <div class="kurs-foto">
      <img src="/assets/img-13fb15be6e83.webp" alt="Doskonalenie pływania dla dzieci" width="533" height="800" loading="lazy">
    </div>
    <div class="kurs-info">
      <h3 class="kurs-nazwa">Doskonalenie<br>pływania dla dzieci</h3>
      <div class="kurs-szczegoly">
        Sobota 9:00 – 15:00<br>
        Niedziela 9:00 – 12:00<br>
        Czas trwania: 45 minut<br>
        ul. Ostrowskiego 3, Wrocław Grabiszyn
      </div>
      <span class="kurs-link">Doskonalenie pływania — szczegóły →</span>
    </div>
  </a>

</section>
<!-- ===== CTA KURSY ===== -->
<div class="cta-band">
  <a href="/zapisy/" class="cta-btn">Zapisz się</a>
</div>
<!-- ===== CO ZABRAĆ ===== -->
<section class="zabrac">
  <div class="zabrac-wrap">
    <div class="zabrac-foto">
      <img src="/assets/hero-dziecko.webp" alt="Dziecko w okularkach pływackich na basenie Solen Swim" width="600" height="399" loading="lazy" />
    </div>
    <div class="zabrac-tresc">
      <h2 class="zabrac-title">Co zabrać<br>na basen?</h2>
      <ul class="zabrac-lista">
        <li>ręcznik kąpielowy</li>
        <li>klapki basenowe</li>
        <li>kąpielówki lub strój kąpielowy</li>
        <li>okularki do pływania</li>
        <li>pielucha wodoodporna dla malucha</li>
      </ul>
    </div>
  </div>
</section>
<!-- ===== CENNIK ===== -->
<section class="cennik">

  <h2 class="cennik-title">Cennik</h2>
  <p class="cennik-subtitle">cena za jedne zajęcia</p>

  <div class="cennik-grid">

    <!-- Karta 1 -->
    <a class="karta" href="/nauka-plywania/niemowleta-i-dzieci-do-4-lat/">
      <div class="karta-top">
        <span class="karta-tag">dla najmłodszych</span>
        <div class="karta-cena"><sup></sup>60<sub> zł</sub></div>
        <span class="karta-czas">30 minut</span>
      </div>
      <div class="karta-body">
        <h3 class="karta-nazwa">Pływanie niemowląt<br>i dzieci do lat 4</h3>
        <span class="karta-wiek">Dziecko + Rodzic · 1–4 lata</span>
        <ul class="karta-lista">
          <li>Sobota 9:00 – 15:00</li>
          <li>Niedziela 9:00 – 12:00</li>
        </ul>
        <span class="karta-note">Rodzic uczestniczy razem z dzieckiem</span>
      </div>
    </a>

    <!-- Karta 2 -->
    <a class="karta" href="/nauka-plywania/dzieci-od-podstaw/">
      <div class="karta-top">
        <span class="karta-tag">od podstaw i doskonalenie</span>
        <div class="karta-cena"><sup></sup>65<sub> zł</sub></div>
        <span class="karta-czas">45 minut</span>
      </div>
      <div class="karta-body">
        <h3 class="karta-nazwa">Nauka i doskonalenie<br>pływania dla dzieci</h3>
        <span class="karta-wiek">5–10 lat</span>
        <ul class="karta-lista">
          <li>Sobota 9:00 – 15:00</li>
          <li>Niedziela 9:00 – 12:00</li>
        </ul>
      </div>
    </a>

  </div>

  <!-- Info bar -->
  <div class="cennik-info">
    <span class="cennik-info-icon">📍</span>
    <div class="cennik-info-text">
      <strong>ul. Ostrowskiego 3, Wrocław Grabiszyn</strong>
      Baseny kryte · bezpłatny parking · zapisy przez formularz kontaktowy
    </div>
  </div>

</section>
<!-- ===== CTA CENNIK ===== -->
<div class="cta-band" style="background:var(--cream);">
  <p style="font-family:var(--font-body);font-size:13px;color:rgba(41,52,52,.55);margin-bottom:14px;letter-spacing:1px;">Dołącz do naszej szkoły pływania</p>
  <a href="/zapisy/" class="cta-btn">Zapisz się na zajęcia</a>
</div>
<!-- ===== OPINIE ===== -->
<section class="opinie-section">
  <h2 class="opinie-title">Opinie rodziców</h2>
  <p class="opinie-rating">⭐ <strong>{site.rating.value.replace('.', ',')} / 5</strong> — {site.rating.count} opinii w Google</p>

  {staticReviews.length > 0 && (
    <div class="opinie-static">
      {staticReviews.map((r) => (
        <blockquote class="opinie-cytat">
          <p>„{r.text}"</p>
          <footer>— {r.author}, opinia Google</footer>
        </blockquote>
      ))}
    </div>
  )}

  {site.reviews.featurableWidgetId ? (
    <div class="opinie-widget">
      <div id={`featurable-${site.reviews.featurableWidgetId}`} data-featurable-async></div>
    </div>
  ) : (
    <p class="opinie-placeholder">Zobacz, co piszą o nas rodzice — przeczytaj wszystkie opinie bezpośrednio w Google.</p>
  )}

  <div class="opinie-akcje">
    <a class="opinie-cta" href={site.reviews.googleProfileUrl} target="_blank" rel="noopener">
      Zobacz opinie w Google
    </a>
    <a class="opinie-cta opinie-cta-outline" href={site.reviews.googleWriteReviewUrl} target="_blank" rel="noopener">
      Wystaw nam opinię ⭐
    </a>
  </div>
</section>
{site.reviews.featurableWidgetId && (
  <script is:inline defer src="https://featurable.com/assets/bundle.js" charset="UTF-8"></script>
)}
<!-- ===== KONTAKT (ciemna sekcja) ===== -->
<div style="background:#293434;"><div class="kontakt">

  <p class="kontakt-eyebrow">kontakt</p>
  <h2 class="kontakt-title">Chcesz z nami<br><span>pływać?</span></h2>
  <p class="kontakt-tagline">swim with the sun · Wrocław</p>

  <ul class="kontakt-lista">

    <li class="kontakt-item">
      <div class="kontakt-ikona">📍</div>
      <div class="kontakt-dane">
        <span class="kontakt-label">Adres</span>
        <span class="kontakt-wartosc">ul. Aleksandra Ostrowskiego 3<br>Wrocław Grabiszyn</span>
      </div>
    </li>

    <li class="kontakt-item">
      <div class="kontakt-ikona">📞</div>
      <div class="kontakt-dane">
        <span class="kontakt-label">Telefon</span>
        <span class="kontakt-wartosc">
          <a href="tel:+48505912389" style="color:inherit;text-decoration:none;">505 912 389</a><br>
          <a href="tel:+48793790711" style="color:inherit;text-decoration:none;">793 790 711</a>
        </span>
      </div>
    </li>

    <li class="kontakt-item">
      <div class="kontakt-ikona">📸</div>
      <div class="kontakt-dane">
        <span class="kontakt-label">Instagram</span>
        <span class="kontakt-wartosc">@szkolaplywania.solenswim</span>
      </div>
    </li>

  </ul>

  <div class="separator"></div>

  <p class="social-label">Obserwuj nas</p>
  <div class="social-lista">

    <!-- Facebook -->
    <a class="social-btn" href={site.social.facebook} target="_blank" rel="noopener" aria-label="Solen Swim na Facebooku">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
      </svg>
    </a>

    <!-- Instagram -->
    <a class="social-btn" href={site.social.instagram} target="_blank" rel="noopener" aria-label="Solen Swim na Instagramie">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5" fill="none" stroke="#FFF9F6" stroke-width="2"/>
        <circle cx="12" cy="12" r="4" fill="none" stroke="#FFF9F6" stroke-width="2"/>
        <circle cx="17.5" cy="6.5" r="1" fill="#FFF9F6"/>
      </svg>
    </a>

  </div>

</div></div>
<!-- ===== MAPA ===== -->
<iframe class="mapa-embed" src="https://www.google.com/maps?q=Szko%C5%82a+P%C5%82ywania+Solen+Swim,+ul.+Aleksandra+Ostrowskiego+3,+Wroc%C5%82aw&output=embed" title="Lokalizacja Solen Swim — ul. Ostrowskiego 3, Wrocław Grabiszyn" loading="lazy"></iframe>
</Base>

<style is:global>
/* === HERO === */
/* Mobile-first: clean mint panel only — no coral, no goggles */
.hero {
    background: var(--mint);
    position: relative;
    overflow: hidden;
  }

  /* Coral pattern + goggles hidden on mobile, restored on desktop */
  .hero-left,
  .hero-goggles {
    display: none;
  }

  .hero-right {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    background: var(--mint);
    padding: 56px 28px 64px;
    text-align: left;
    position: relative;
    z-index: 2;
  }

  .hero-eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--dark);
    opacity: 0.55;
    margin-bottom: 14px;
  }

  .hero-h1 {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(32px, 9vw, 48px);
    color: var(--coral);
    line-height: 1.1;
    margin-bottom: 20px;
    letter-spacing: -0.5px;
    max-width: 100%;
  }

  .hero-desc {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.75;
    color: var(--dark);
    max-width: 360px;
    margin-bottom: 32px;
    opacity: 0.8;
  }

  .hero-cta {
    display: inline-block;
    background: var(--coral);
    color: var(--cream);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 1px;
    padding: 14px 38px;
    border-radius: 100px;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 8px 24px rgba(255,131,87,0.28);
  }

  .hero-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(255,131,87,0.40);
  }

  /* Desktop: staggered blocks like Wix — coral upper-left, mint lower-right, cream bg */
  @media (min-width: 768px) {
    .hero {
      display: block;
      background: var(--cream);
      position: relative;
      height: 480px;
    }

    .hero-left {
      display: block;
      position: absolute;
      left: 0; top: 0;
      width: 63%; height: 74%;
      background-color: var(--coral);
      background-image: url('/assets/pattern-slonce.webp');
      background-repeat: repeat;
      /* 4 suns per row, same as Wix rendering (2000px source downscaled to panel width) */
      background-size: 100% auto;
      background-position: top left;
    }

    .hero-right {
      position: absolute;
      right: 0; bottom: 0;
      width: 50%; top: 18%;
      background: var(--mint);
      padding: 44px 6% 44px 13%;
      min-height: auto;
      align-items: flex-start;
      text-align: left;
      justify-content: center;
    }

    .hero-eyebrow {
      font-size: 10px;
      letter-spacing: 2px;
      margin-bottom: 12px;
    }

    .hero-h1 {
      max-width: 100%;
      font-size: clamp(30px, 3.2vw, 52px);
      margin-bottom: 20px;
    }

    .hero-desc {
      font-size: 13px;
      line-height: 1.75;
      max-width: 340px;
      margin-bottom: 36px;
    }

    .hero-cta {
      font-size: 15px;
      padding: 16px 44px;
      box-shadow: 0 8px 32px rgba(255,131,87,0.30);
    }

    .hero-goggles {
      display: block;
      position: absolute;
      width: clamp(360px, 33vw, 530px);
      left: 21vw;
      top: 50%;
      transform: translateY(-48%);
      z-index: 10;
      right: auto;
    }
  }
/* === KURSY === */
.kursy {
  padding: 80px 6%;
  max-width: 1200px;
  margin: 0 auto;
}

/* TYTUŁ */
.kursy-title {
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: 46px;
  letter-spacing: 6px;
  text-transform: uppercase;
  color: #B6DEDD;
  text-align: center;
  margin-bottom: 72px;
}

/* POJEDYNCZY KURS — klikalna karta prowadząca do podstrony kursu */
.kurs {
  display: flex;
  align-items: center;
  gap: 72px;
  margin-bottom: 80px;
  text-decoration: none;
  color: inherit;
  border-radius: 24px;
  transition: transform .25s;
}

.kurs:hover {
  transform: translateY(-3px);
  color: inherit;
}

.kurs:hover .kurs-link {
  color: #293434;
}

.kurs-link {
  display: inline-block;
  margin-top: 14px;
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: 12px;
  letter-spacing: .5px;
  color: #FF8357;
  transition: color .2s;
}

/* Naprzemienne — co drugi kurs odwraca kolejność */
.kurs.odwrocony {
  flex-direction: row-reverse;
}

/* OKRĄGŁE ZDJĘCIE */
.kurs-foto {
  flex-shrink: 0;
  width: 300px;
  height: 300px;
  border-radius: 50%;
  overflow: hidden;
  background: #B6DEDD;
}

.kurs-foto img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Placeholder gdy nie ma zdjęcia */
.kurs-foto.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  color: #293434;
  opacity: 0.4;
  text-align: center;
  font-family: 'Space Mono', monospace;
  line-height: 1.5;
}

/* TEKST KURSU */
.kurs-info {}

.kurs-nazwa {
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: 20px;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: #FF8357;
  line-height: 1.25;
  margin-bottom: 18px;
}

.kurs-szczegoly {
  font-family: 'Space Mono', monospace;
  font-size: 13px;
  line-height: 2;
  color: #293434;
}

.kurs-szczegoly .label {
  display: block;
  margin-top: 6px;
  margin-bottom: 2px;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  opacity: 0.5;
}

.kurs-wyroznienie {
  display: inline-block;
  margin-top: 10px;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #86C6C4;
  font-weight: 700;
}

/* ── TABLET (≤760px) ── */
@media (max-width: 760px) {
  .kursy {
    padding: 56px 5%;
  }
  /* zachowaj układ obok siebie jak w wizualizacji */
  .kurs, .kurs.odwrocony {
    flex-direction: row;
    align-items: center;
    text-align: left;
    gap: 28px;
    margin-bottom: 52px;
  }
  .kurs.odwrocony {
    flex-direction: row-reverse;
  }
  .kurs-foto {
    width: 160px;
    height: 160px;
    flex-shrink: 0;
  }
  .kursy-title { font-size: 28px; }
  .kurs-nazwa { font-size: 17px; }
  .kurs-szczegoly { font-size: 12px; }
}

/* ── MOBILE (≤480px) ── */
@media (max-width: 480px) {
  .kursy {
    padding: 40px 4%;
  }
  .kursy-title {
    font-size: 22px;
    letter-spacing: 2px;
    margin-bottom: 36px;
  }
  .kurs, .kurs.odwrocony {
    flex-direction: row;
    align-items: center;
    text-align: left;
    gap: 16px;
    margin-bottom: 40px;
  }
  .kurs.odwrocony {
    flex-direction: row-reverse;
  }
  .kurs-foto {
    width: 120px;
    height: 120px;
    flex-shrink: 0;
  }
  .kurs-nazwa {
    font-size: 14px;
    letter-spacing: 0.5px;
  }
  .kurs-szczegoly {
    font-size: 11px;
    line-height: 1.8;
  }
  .kurs-wyroznienie {
    font-size: 10px;
  }
}
/* === CO ZABRAĆ === */
.zabrac {
  background: var(--cream);
  padding: 72px 6%;
}
.zabrac-wrap {
  max-width: 1100px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 32px;
  align-items: center;
}
.zabrac-foto {
  width: 100%;
}
.zabrac-foto img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 8px;
  object-fit: cover;
}
.zabrac-tresc {
  width: 100%;
}
.zabrac-title {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: clamp(30px, 6vw, 52px);
  color: var(--mint);
  line-height: 1.1;
  margin-bottom: 28px;
  text-transform: uppercase;
}
.zabrac-lista {
  list-style: none;
  padding: 0;
  margin: 0;
}
.zabrac-lista li {
  font-family: var(--font-body);
  font-size: clamp(14px, 1.6vw, 17px);
  color: var(--coral);
  line-height: 1.5;
  padding-left: 22px;
  margin-bottom: 16px;
  position: relative;
}
.zabrac-lista li::before {
  content: '•';
  position: absolute;
  left: 0;
  color: var(--coral);
  font-size: 1.2em;
