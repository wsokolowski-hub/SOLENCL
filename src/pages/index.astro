---
import Base from '@/layouts/Base.astro';
const title = 'Szkoła Pływania Wrocław | Solen Swim | Dzieci od 6 miesiąca';
const description = 'Szkoła pływania dla dzieci i niemowląt we Wrocławiu (Grabiszyn). Zajęcia od 6. miesiąca życia. Małe grupy, certyfikowani instruktorzy. 4,9/5 (21 opinii). Zapisz się online.';
const path = '/';
const pageType = 'home' as const;
const breadcrumbs = [];
---
<Base title={title} description={description} path={path} pageType={pageType} breadcrumbs={breadcrumbs}>
<!-- ===== HERO ===== -->
<section class="hero">
  <div class="hero-left"></div>
  <div class="hero-right">
    <p class="hero-eyebrow">Nauka pływania dla dzieci · Wrocław</p>
    <h1 class="hero-h1">Szkoła Pływania<br>Solen Swim</h1>
    <p class="hero-desc">Zacznij pływać z <strong>Solen Swim!</strong> Oferujemy zajęcia na różnych poziomach, łącząc naukę z zabawą. Dołącz do nas już dziś!</p>
    <a class="hero-cta" href="/zapisy/">Zapisz się</a>
  </div>
  <img class="hero-goggles" src="/assets/okularki.webp" alt="Okularki pływackie Solen Swim">
</section>
<!-- ===== KURSY ===== -->
<section class="kursy">

  <h2 class="kursy-title">Nasze kursy</h2>

  <!-- KURS 1 -->
  <div class="kurs">
    <div class="kurs-foto">
      <img src="/assets/img-924d79bd96e8.jpg" alt="Pływanie niemowląt i dzieci do lat 4">
    </div>
    <div class="kurs-info">
      <h3 class="kurs-nazwa">Pływanie niemowląt<br>i dzieci do lat 4</h3>
      <div class="kurs-szczegoly">
        Czwartki 15:30 – 18:30<br>
        Sobota 9:00 – 15:00<br>
        Niedziela 10:00 – 12:00<br>
        <span class="kurs-wyroznienie">Rodzic uczestniczy razem z dzieckiem</span><br>
        Czas trwania: 30 minut<br>
        ul. Ostrowskiego 3, Wrocław Grabiszyn
      </div>
    </div>
  </div>

  <!-- KURS 2 — odwrócony -->
  <div class="kurs odwrocony">
    <div class="kurs-foto">
      <img src="/assets/img-20f0624ea60b.jpg" alt="Nauka pływania dla dzieci od podstaw">
    </div>
    <div class="kurs-info">
      <h3 class="kurs-nazwa">Nauka pływania dla<br>dzieci od podstaw</h3>
      <div class="kurs-szczegoly">
        <span class="label">Zajęcia:</span>
        Czwartki 15:30 – 18:30<br>
        Sobota 9:00 – 15:00<br>
        Czas trwania: 45 minut<br>
        ul. Ostrowskiego 3, Wrocław Grabiszyn
      </div>
    </div>
  </div>

  <!-- KURS 3 -->
  <div class="kurs">
    <div class="kurs-foto">
      <img src="/assets/img-13fb15be6e83.jpg" alt="Doskonalenie pływania dla dzieci">
    </div>
    <div class="kurs-info">
      <h3 class="kurs-nazwa">Doskonalenie<br>pływania dla dzieci</h3>
      <div class="kurs-szczegoly">
        Sobota 9:00 – 15:00<br>
        Czas trwania: 45 minut<br>
        ul. Ostrowskiego 3, Wrocław Grabiszyn
      </div>
    </div>
  </div>

</section>
<!-- ===== CTA KURSY ===== -->
<div class="cta-band">
  <a href="/zapisy/" class="cta-btn">Zapisz się</a>
</div>
<!-- ===== CO ZABRAĆ ===== -->
<div style="background:#B6DEDD;"><div class="section">
  <p class="section-label">przygotowanie</p>
  <h2 class="section-title">Co zabrać na basen?</h2>

  <div class="checklist">
    <div class="check-item">
      <div class="check-icon">🏊</div>
      <span class="check-text">Kąpielówki lub strój kąpielowy</span>
    </div>
    <div class="check-item">
      <div class="check-icon">🥽</div>
      <span class="check-text">Okularki do pływania</span>
    </div>
    <div class="check-item">
      <div class="check-icon">🩴</div>
      <span class="check-text">Klapki basenowe</span>
    </div>
    <div class="check-item">
      <div class="check-icon">🛁</div>
      <span class="check-text">Ręcznik kąpielowy</span>
    </div>
    <div class="check-item highlight">
      <div class="check-icon">👶</div>
      <span class="check-text">Pielucha wodoodporna<br><small style="opacity:0.8; font-size:11px;">tylko dla maluszków</small></span>
    </div>
  </div>

  <div class="note-box">
    <span class="note-emoji">📍</span>
    <div class="note-content">
      <p class="note-title">Gdzie pływamy?</p>
      <p class="note-text">Zajęcia odbywają się na basenie krytym przy ul. Ostrowskiego 3, Wrocław Grabiszyn. Bezpłatny parking dla uczestników zajęć.</p>
    </div>
  </div>
</div></div>
<!-- ===== CENNIK ===== -->
<section class="cennik">

  <h2 class="cennik-title">Cennik</h2>
  <p class="cennik-subtitle">cena za jedne zajęcia</p>

  <div class="cennik-grid">

    <!-- Karta 1 -->
    <div class="karta">
      <div class="karta-top">
        <span class="karta-tag">dla najmłodszych</span>
        <div class="karta-cena"><sup></sup>55<sub> zł</sub></div>
        <span class="karta-czas">30 minut</span>
      </div>
      <div class="karta-body">
        <h3 class="karta-nazwa">Pływanie niemowląt<br>i dzieci do lat 4</h3>
        <span class="karta-wiek">Dziecko + Rodzic · 1–4 lata</span>
        <ul class="karta-lista">
          <li>Czwartki 15:30 – 18:30</li>
          <li>Sobota 9:00 – 15:00</li>
          <li>Niedziela 10:00 – 12:00</li>
        </ul>
        <span class="karta-note">Rodzic uczestniczy razem z dzieckiem</span>
      </div>
    </div>

    <!-- Karta 2 -->
    <div class="karta">
      <div class="karta-top">
        <span class="karta-tag">od podstaw i doskonalenie</span>
        <div class="karta-cena"><sup></sup>65<sub> zł</sub></div>
        <span class="karta-czas">45 minut</span>
      </div>
      <div class="karta-body">
        <h3 class="karta-nazwa">Nauka i doskonalenie<br>pływania dla dzieci</h3>
        <span class="karta-wiek">5–10 lat</span>
        <ul class="karta-lista">
          <li>Czwartki 15:30 – 18:30</li>
          <li>Sobota 9:00 – 15:00</li>
        </ul>
      </div>
    </div>

  </div>

  <!-- Info bar -->
  <div class="cennik-info">
    <span class="cennik-info-icon">📍</span>
    <div class="cennik-info-text">
      <strong>ul. Ostrowskiego 3, Wrocław Grabiszyn</strong>
      Baseny kryte · bezpłatny parking · zapisy przez formularz kontaktowy
    </div>
  </div>

</section>
<!-- ===== CTA CENNIK ===== -->
<div class="cta-band" style="background:var(--cream);">
  <p style="font-family:var(--font-body);font-size:13px;color:rgba(41,52,52,.55);margin-bottom:14px;letter-spacing:1px;">Dołącz do naszej szkoły pływania</p>
  <a href="/zapisy/" class="cta-btn">Zapisz się na zajęcia</a>
</div>
<!-- ===== OPINIE ===== -->
<section class="opinie-section">
  <h2 class="opinie-title">Opinie</h2>
  <div class="opinie-stars" aria-label="Ocena 4,9 na 5">★★★★★</div>
  <p class="opinie-rating">4,9 / 5 · 21 opinii w Google</p>
  <div class="opinie-scroll">
    <div class="opinia">
      <div class="opinia-top"><span class="opinia-av">R</span><div><b>Rafał</b><span>Październik 2025</span></div></div>
      <div class="opinia-gw">★★★★★</div>
      <p>Profesjonalne, cierpliwe podejście. Dzieci czują się bezpiecznie i chętnie chodzą na zajęcia. Polecam!</p>
    </div>
    <div class="opinia">
      <div class="opinia-top"><span class="opinia-av mint">A</span><div><b>Anna</b><span>Październik 2025</span></div></div>
      <div class="opinia-gw">★★★★★</div>
      <p>Kameralna atmosfera, ogrzewana woda, doświadczeni instruktorzy. Córka robi ogromne postępy.</p>
    </div>
    <div class="opinia">
      <div class="opinia-top"><span class="opinia-av">N</span><div><b>Natalia</b><span>Wrzesień 2025</span></div></div>
      <div class="opinia-gw">★★★★★</div>
      <p>Świetne zajęcia dla niemowląt! Instruktorki są cudowne, maluszek absolutnie uwielbia wodę.</p>
    </div>
  </div>
</section>
<!-- ===== KONTAKT (ciemna sekcja) ===== -->
<div style="background:#293434;"><div class="kontakt">

  <p class="kontakt-eyebrow">kontakt</p>
  <h2 class="kontakt-title">Chcesz z nami<br><span>pływać?</span></h2>
  <p class="kontakt-tagline">swim with the sun · Wrocław</p>

  <ul class="kontakt-lista">

    <li class="kontakt-item">
      <div class="kontakt-ikona">📍</div>
      <div class="kontakt-dane">
        <span class="kontakt-label">Adres</span>
        <span class="kontakt-wartosc">ul. Aleksandra Ostrowskiego 3<br>Wrocław Grabiszyn</span>
      </div>
    </li>

    <li class="kontakt-item">
      <div class="kontakt-ikona">📞</div>
      <div class="kontakt-dane">
        <span class="kontakt-label">Telefon</span>
        <span class="kontakt-wartosc">
          <a href="tel:+48505912389" style="color:inherit;text-decoration:none;">505 912 389</a><br>
          <a href="tel:+48793790711" style="color:inherit;text-decoration:none;">793 790 711</a>
        </span>
      </div>
    </li>

    <li class="kontakt-item">
      <div class="kontakt-ikona">📸</div>
      <div class="kontakt-dane">
        <span class="kontakt-label">Instagram</span>
        <span class="kontakt-wartosc">@szkolaplywania.solenswim</span>
      </div>
    </li>

  </ul>

  <div class="separator"></div>

  <p class="social-label">Obserwuj nas</p>
  <div class="social-lista">

    <!-- Facebook -->
    <div class="social-btn">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
      </svg>
    </div>

    <!-- Instagram -->
    <div class="social-btn">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5" fill="none" stroke="#FFF9F6" stroke-width="2"/>
        <circle cx="12" cy="12" r="4" fill="none" stroke="#FFF9F6" stroke-width="2"/>
        <circle cx="17.5" cy="6.5" r="1" fill="#FFF9F6"/>
      </svg>
    </div>

  </div>

</div></div>
<!-- ===== MAPA ===== -->
<iframe class="mapa-embed" src="https://www.google.com/maps?q=ul.+Aleksandra+Ostrowskiego+3,+54-411+Wroc%C5%82aw&output=embed" title="Lokalizacja Solen Swim — ul. Ostrowskiego 3, Wrocław Grabiszyn" loading="lazy"></iframe>
</Base>

<style is:global>
/* === HERO === */
/* Mobile first: single-column, mint background */
.hero {
    background: var(--cream);
    position: relative;
    overflow: hidden;
  }

  /* Left panel (coral sun pattern) — desktop only */
  .hero-left {
    display: none;
  }

  /* Mobile: cream bg, text left, goggles absolute top-right */
  .hero-right {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    background: var(--cream);
    padding: 48px 24px 64px;
    text-align: left;
    position: relative;
    z-index: 2;
    min-height: 380px;
  }

  .hero-eyebrow {
    font-family: var(--font-body);
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--dark);
    opacity: 0.55;
    margin-bottom: 12px;
  }

  .hero-h1 {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(34px, 9vw, 66px);
    color: var(--coral);
    line-height: 1.1;
    margin-bottom: 20px;
    letter-spacing: -1px;
    max-width: 55%;
  }

  .hero-desc {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.75;
    color: var(--dark);
    max-width: 340px;
    margin-bottom: 36px;
    opacity: 0.8;
  }

  .hero-cta {
    display: inline-block;
    background: var(--coral);
    color: var(--cream);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 1px;
    padding: 16px 44px;
    border-radius: 100px;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 8px 32px rgba(255,131,87,0.30);
  }

  .hero-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(255,131,87,0.40);
  }

  /* Goggles — mobile: absolute, top-right corner overlapping H1 */
  .hero-goggles {
    position: absolute;
    width: 170px;
    right: -10px;
    top: 36px;
    z-index: 3;
    display: block;
    transform: rotate(-8deg);
  }

  /* Desktop: staggered blocks like Wix — coral upper-left, mint lower-right, cream bg */
  @media (min-width: 768px) {
    .hero {
      display: block;
      background: var(--cream);
      position: relative;
      height: 480px;
    }

    .hero-left {
      display: block;
      position: absolute;
      left: 0; top: 0;
      width: 63%; height: 74%;
      background-color: var(--coral);
      background-image: url('/assets/pattern-slonce.webp');
      background-repeat: repeat;
      background-size: 480px 480px;
      background-position: top left;
    }

    .hero-right {
      position: absolute;
      right: 0; bottom: 0;
      width: 50%; top: 18%;
      background: var(--mint);
      padding: 44px 6% 44px 13%;
      min-height: auto;
      align-items: flex-start;
      text-align: left;
      justify-content: center;
    }

    .hero-h1 {
      max-width: 100%;
      font-size: clamp(30px, 3.2vw, 52px);
    }

    .hero-goggles {
      position: absolute;
      width: 300px;
      left: calc(50% - 220px);
      top: 50%;
      transform: translateY(-45%);
      z-index: 10;
      right: auto;
    }
  }
/* === KURSY === */
.kursy {
  padding: 80px 6%;
  max-width: 1200px;
  margin: 0 auto;
}

/* TYTUŁ */
.kursy-title {
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: 46px;
  letter-spacing: 6px;
  text-transform: uppercase;
  color: #B6DEDD;
  text-align: center;
  margin-bottom: 72px;
}

/* POJEDYNCZY KURS */
.kurs {
  display: flex;
  align-items: center;
  gap: 72px;
  margin-bottom: 80px;
}

/* Naprzemienne — co drugi kurs odwraca kolejność */
.kurs.odwrocony {
  flex-direction: row-reverse;
}

/* OKRĄGŁE ZDJĘCIE */
.kurs-foto {
  flex-shrink: 0;
  width: 300px;
  height: 300px;
  border-radius: 50%;
  overflow: hidden;
  background: #B6DEDD;
}

.kurs-foto img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Placeholder gdy nie ma zdjęcia */
.kurs-foto.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  color: #293434;
  opacity: 0.4;
  text-align: center;
  font-family: 'Space Mono', monospace;
  line-height: 1.5;
}

/* TEKST KURSU */
.kurs-info {}

.kurs-nazwa {
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: 20px;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: #FF8357;
  line-height: 1.25;
  margin-bottom: 18px;
}

.kurs-szczegoly {
  font-family: 'Space Mono', monospace;
  font-size: 13px;
  line-height: 2;
  color: #293434;
}

.kurs-szczegoly .label {
  display: block;
  margin-top: 6px;
  margin-bottom: 2px;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  opacity: 0.5;
}

.kurs-wyroznienie {
  display: inline-block;
  margin-top: 10px;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #86C6C4;
  font-weight: 700;
}

/* ── TABLET (≤760px) ── */
@media (max-width: 760px) {
  .kursy {
    padding: 56px 5%;
  }
  /* zachowaj układ obok siebie jak w wizualizacji */
  .kurs, .kurs.odwrocony {
    flex-direction: row;
    align-items: center;
    text-align: left;
    gap: 28px;
    margin-bottom: 52px;
  }
  .kurs.odwrocony {
    flex-direction: row-reverse;
  }
  .kurs-foto {
    width: 160px;
    height: 160px;
    flex-shrink: 0;
  }
  .kursy-title { font-size: 28px; }
  .kurs-nazwa { font-size: 17px; }
  .kurs-szczegoly { font-size: 12px; }
}

/* ── MOBILE (≤480px) ── */
@media (max-width: 480px) {
  .kursy {
    padding: 40px 4%;
  }
  .kursy-title {
    font-size: 22px;
    letter-spacing: 2px;
    margin-bottom: 36px;
  }
  .kurs, .kurs.odwrocony {
    flex-direction: row;
    align-items: center;
    text-align: left;
    gap: 16px;
    margin-bottom: 40px;
  }
  .kurs.odwrocony {
    flex-direction: row-reverse;
  }
  .kurs-foto {
    width: 120px;
    height: 120px;
    flex-shrink: 0;
  }
  .kurs-nazwa {
    font-size: 14px;
    letter-spacing: 0.5px;
  }
  .kurs-szczegoly {
    font-size: 11px;
    line-height: 1.8;
  }
  .kurs-wyroznienie {
    font-size: 10px;
  }
}
/* === CO ZABRAĆ === */
.section {
    padding: 80px 24px;
    max-width: 900px;
    margin: 0 auto;
  }

  .section-label {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--coral);
    text-align: center;
    margin-bottom: 12px;
  }

  .section-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(28px, 5vw, 44px);
    color: var(--dark);
    text-align: center;
    margin-bottom: 48px;
  }

  .checklist {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 16px;
  }

  .check-item {
    background: var(--cream);
    border-radius: 18px;
    padding: 20px 24px;
    display: flex;
    align-items: center;
    gap: 16px;
    transition: transform 0.15s;
  }
  .check-item:hover { transform: translateX(4px); }

  .check-icon {
    width: 44px; height: 44px;
    border-radius: 12px;
    background: var(--mint);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    flex-shrink: 0;
  }

  .check-text {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--dark);
    line-height: 1.4;
  }

  /* Specjalne wyróżnienie dla ostatniego elementu (pielucha) */
  .check-item.highlight {
    background: var(--salmon);
  }
  .check-item.highlight .check-icon { background: rgba(255,249,246,0.4); }
  .check-item.highlight .check-text { color: var(--cream); }

  .note-box {
    margin-top: 40px;
    background: var(--cream);
    border-radius: 20px;
    padding: 28px 32px;
    display: flex;
    align-items: flex-start;
    gap: 20px;
  }
  .note-emoji { font-size: 32px; flex-shrink: 0; }
  .note-content {}
  .note-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 16px;
    color: var(--coral);
    margin-bottom: 6px;
  }
  .note-text {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--dark);
    opacity: 0.75;
    line-height: 1.6;
  }
/* === CENNIK === */
.cennik {
  padding: 80px 6%;
  max-width: 1200px;
  margin: 0 auto;
}

/* TYTUŁ */
.cennik-title {
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: 46px;
  letter-spacing: 6px;
  text-transform: uppercase;
  color: #B6DEDD;
  text-align: center;
  margin-bottom: 16px;
}

.cennik-subtitle {
  text-align: center;
  font-size: 13px;
  color: #293434;
  opacity: 0.55;
  letter-spacing: 2px;
  margin-bottom: 64px;
}

/* KARTY */
.cennik-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 28px;
  max-width: 820px;
  margin: 0 auto;
}

.karta {
  background: #FFF9F6;
