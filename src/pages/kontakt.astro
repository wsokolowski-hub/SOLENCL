---
import Base from '@/layouts/Base.astro';
const title = 'Kontakt | Szkoła Pływania Solen Swim — Wrocław Grabiszyn';
const description = 'Skontaktuj się ze szkołą pływania Solen Swim we Wrocławiu. Tel: 505 912 389. Adres: ul. Aleksandra Ostrowskiego 3, Grabiszyn. Darmowy parking.';
const path = '/kontakt/';
const pageType = 'contact' as const;
const breadcrumbs = [{ name: "Start", href: "/" }, { name: "Kontakt", href: "/kontakt/" }];
---
<Base title={title} description={description} path={path} pageType={pageType} breadcrumbs={breadcrumbs}>
<!-- HERO -->
<div class="kt-hero">
  <span class="kt-eyebrow">Kontakt</span>
  <h1 class="kt-title">Chcesz z nami<br><span>pływać?</span></h1>
  <p class="kt-tagline">swim with the sun · Wrocław</p>
</div>

<!-- GRID DANYCH KONTAKTOWYCH -->
<div class="kt-grid">

  <!-- Adres — nieklikalny -->
  <div class="kt-karta">
    <div class="kt-karta-ikona">📍</div>
    <div>
      <span class="kt-karta-label">Adres</span>
      <p class="kt-karta-wartosc">ul. Aleksandra Ostrowskiego 3</p>
      <span class="kt-karta-sub">Wrocław · dzielnica Grabiszyn</span>
    </div>
  </div>

  <!-- Telefon — KLIKALNY -->
  <a class="kt-karta" href="tel:+48505912389" target="_blank">
    <div class="kt-karta-ikona coral">📞</div>
    <div>
      <span class="kt-karta-label">Telefon</span>
      <p class="kt-karta-wartosc">505 912 389</p>
      <span class="kt-karta-sub">793 790 711</span>
    </div>
  </a>

  <!-- Email — KLIKALNY -->
  <a class="kt-karta" href="mailto:solenswim@outlook.com">
    <div class="kt-karta-ikona">✉️</div>
    <div>
      <span class="kt-karta-label">E-mail</span>
      <p class="kt-karta-wartosc">solenswim@outlook.com</p>
      <span class="kt-karta-sub">Odpowiadamy w ciągu 24h</span>
    </div>
  </a>

  <!-- Obiekt — nieklikalny -->
  <div class="kt-karta">
    <div class="kt-karta-ikona coral">🏊</div>
    <div>
      <span class="kt-karta-label">Obiekt</span>
      <p class="kt-karta-wartosc">Baseny kryte</p>
      <span class="kt-karta-sub">Bezpłatny parking przy obiekcie</span>
    </div>
  </div>

</div>

<!-- SOCIAL MEDIA -->
<div class="kt-social">
  <span class="kt-social-eyebrow">Obserwuj nas</span>
  <div class="kt-social-row">

    <!-- Facebook — KLIKALNY -->
    <a class="kt-social-btn" href="https://www.facebook.com/profile.php?id=61581816024136" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
      </svg>
      <div class="kt-social-btn-tekst">
        <span class="kt-social-btn-label">Facebook</span>
        <span class="kt-social-btn-nazwa">Szkoła pływania Solen Swim</span>
      </div>
    </a>

    <!-- Instagram — KLIKALNY -->
    <a class="kt-social-btn" href="https://www.instagram.com/szkolaplywania.solenswim/" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5" fill="none" stroke="#FFF9F6" stroke-width="2"/>
        <circle cx="12" cy="12" r="4" fill="none" stroke="#FFF9F6" stroke-width="2"/>
        <circle cx="17.5" cy="6.5" r="1" fill="#FFF9F6"/>
      </svg>
      <div class="kt-social-btn-tekst">
        <span class="kt-social-btn-label">Instagram</span>
        <span class="kt-social-btn-nazwa">@szkolaplywania.solenswim</span>
      </div>
    </a>

  </div>
</div>

<div class="kt-separator"></div>

<!-- INFO O FORMULARZU -->
<div class="kt-formularz-info">
  <div class="kt-form-box">
    <div>
      <span class="kt-form-box-eyebrow">Formularz kontaktowy</span>
      <p class="kt-form-box-title">Napisz do nas —<br>oddzwonimy!</p>
      <p class="kt-form-box-sub">Wypełnij formularz poniżej a my skontaktujemy się z Tobą w ciągu 24 godzin, aby omówić szczegóły i dobrać odpowiedni kurs dla Twojego dziecka.</p>
    </div>
    <span class="kt-form-box-ikona">💬</span>
  </div>
</div>
</Base>

<style is:global>
* { margin: 0; padding: 0; box-sizing: border-box; }

/* Blokada auto-linkowania przez iOS/Android */
a[x-apple-data-detectors] {
  color: inherit !important;
  text-decoration: none !important;
  pointer-events: none;
}

body {
  background: #293434;
  font-family: 'Space Mono', monospace;
  color: #FFF9F6;
}

/* ─── HERO ─── */
.kt-hero {
  padding: 72px 6% 56px;
  position: relative;
  overflow: hidden;
}

.kt-hero::before {
  content: '';
  position: absolute;
  width: 360px; height: 360px;
  border-radius: 50%;
  background: rgba(182,222,221,0.07);
  top: -120px; right: -80px;
}

.kt-eyebrow {
  font-size: 10px;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: #B6DEDD;
  opacity: 0.7;
  margin-bottom: 16px;
  display: block;
}

.kt-title {
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: clamp(32px, 6vw, 62px);
  color: #FFF9F6;
  line-height: 1.1;
  margin-bottom: 16px;
}

.kt-title span { color: #FF8357; }

.kt-tagline {
  font-size: 13px;
  color: #B6DEDD;
  opacity: 0.7;
  letter-spacing: 2px;
}

/* ─── GRID DANYCH ─── */
.kt-grid {
  padding: 0 6% 72px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
  max-width: 1200px;
  margin: 0 auto;
}

/* KARTA KONTAKTOWA */
.kt-karta {
  background: rgba(255,249,246,0.05);
  border: 1px solid rgba(182,222,221,0.12);
  border-radius: 20px;
  padding: 28px 28px;
  display: flex;
  align-items: flex-start;
  gap: 18px;
  transition: background 0.2s, transform 0.2s;
  text-decoration: none;
  color: inherit;
}

/* Klikalne karty (a href) */
a.kt-karta {
  cursor: pointer;
}

a.kt-karta:hover {
  background: rgba(255,131,87,0.12);
  border-color: rgba(255,131,87,0.3);
  transform: translateY(-2px);
}

/* Nieklikalne karty (div) */
div.kt-karta:hover {
  background: rgba(255,249,246,0.08);
}

.kt-karta-ikona {
  width: 48px;
  height: 48px;
  border-radius: 14px;
  background: rgba(182,222,221,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  flex-shrink: 0;
}

.kt-karta-ikona.coral { background: rgba(255,131,87,0.18); }

.kt-karta-label {
  font-size: 9px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #B6DEDD;
  opacity: 0.6;
  display: block;
  margin-bottom: 6px;
}

.kt-karta-wartosc {
  font-size: 15px;
  color: #FFF9F6;
  font-weight: 700;
  line-height: 1.5;
  font-family: 'Comfortaa', sans-serif;
}

.kt-karta-sub {
  font-size: 12px;
  color: #B6DEDD;
  opacity: 0.65;
  margin-top: 4px;
  display: block;
  font-family: 'Space Mono', monospace;
}

/* ─── SOCIAL MEDIA ─── */
.kt-social {
  padding: 0 6% 56px;
  max-width: 1200px;
  margin: 0 auto;
}

.kt-social-eyebrow {
  font-size: 9px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #B6DEDD;
  opacity: 0.6;
  display: block;
  margin-bottom: 16px;
}

.kt-social-row {
  display: flex;
  gap: 14px;
}

.kt-social-btn {
  display: flex;
  align-items: center;
  gap: 12px;
  background: rgba(255,249,246,0.06);
  border: 1px solid rgba(255,249,246,0.1);
  border-radius: 14px;
  padding: 14px 22px;
  cursor: pointer;
  transition: background 0.2s, transform 0.2s, border-color 0.2s;
  text-decoration: none;
  color: inherit;
}

.kt-social-btn:hover {
  background: rgba(255,131,87,0.15);
  border-color: rgba(255,131,87,0.35);
  transform: translateY(-2px);
}

.kt-social-btn svg {
  width: 20px;
  height: 20px;
  fill: #FFF9F6;
  flex-shrink: 0;
}

.kt-social-btn-tekst {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.kt-social-btn-label {
  font-size: 9px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #B6DEDD;
  opacity: 0.6;
}

.kt-social-btn-nazwa {
  font-size: 13px;
  color: #FFF9F6;
  font-weight: 700;
}

/* ─── SEPARATOR ─── */
.kt-separator {
  margin: 0 6% 56px;
  height: 1px;
  background: rgba(182,222,221,0.12);
  max-width: 1200px;
}

/* ─── FORMULARZ INFO ─── */
.kt-formularz-info {
  padding: 0 6% 72px;
  max-width: 1200px;
  margin: 0 auto;
}

.kt-form-box {
  background: #FF8357;
  border-radius: 24px;
  padding: 40px 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 32px;
}

.kt-form-box-eyebrow {
  font-size: 9px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #FFF9F6;
  opacity: 0.75;
  display: block;
  margin-bottom: 10px;
}

.kt-form-box-title {
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: 24px;
  color: #FFF9F6;
  line-height: 1.3;
  margin-bottom: 8px;
}

.kt-form-box-sub {
  font-size: 13px;
  color: #FFF9F6;
  opacity: 0.8;
  line-height: 1.6;
}

.kt-form-box-ikona {
  font-size: 56px;
  flex-shrink: 0;
  opacity: 0.85;
}

/* ── TABLET ── */
@media (max-width: 760px) {
  .kt-hero { padding: 56px 5% 44px; }
  .kt-grid { padding: 0 5% 52px; grid-template-columns: 1fr; gap: 16px; }
  .kt-social { padding: 0 5% 44px; }
  .kt-social-row { flex-direction: column; }
  .kt-separator { margin: 0 5% 44px; }
  .kt-formularz-info { padding: 0 5% 52px; }
  .kt-form-box { flex-direction: column; align-items: flex-start; padding: 32px 28px; }
  .kt-form-box-ikona { display: none; }
}

/* ── MOBILE ── */
@media (max-width: 480px) {
  .kt-hero { padding: 44px 4% 36px; }
  .kt-grid { padding: 0 4% 40px; }
  .kt-karta { padding: 20px 18px; }
  .kt-karta-ikona { width: 42px; height: 42px; font-size: 18px; }
  .kt-karta-wartosc { font-size: 14px; }
  .kt-social { padding: 0 4% 36px; }
  .kt-separator { margin: 0 4% 36px; }
  .kt-formularz-info { padding: 0 4% 48px; }
  .kt-form-box { padding: 26px 22px; border-radius: 18px; gap: 16px; }
  .kt-form-box-title { font-size: 20px; }
}
</style>
