---
import Base from '@/layouts/Base.astro';
const title = 'Szkoła pływania dla dzieci Wrocław Grabiszyn | Solen Swim';
const description = 'Poznaj Solen Swim i założycielkę Kamilę Falkowską. Weekendowe zajęcia dla dzieci 6 mies.–10 lat, grupy max 8 osób. Wrocław Grabiszyn, ul. Ostrowskiego 3.';
const path = '/o-nas/';
const pageType = 'about' as const;
const breadcrumbs = [{ name: "Start", href: "/" }, { name: "O nas", href: "/o-nas/" }];
---
<Base title={title} description={description} path={path} pageType={pageType} breadcrumbs={breadcrumbs}>
<!-- HERO -->
<div class="onas-hero">
  <span class="onas-eyebrow">Solen Swim · Wrocław</span>
  <h1 class="onas-title">Szkoła pływania dla dzieci we&nbsp;Wrocławiu — poznaj <span>Solen Swim</span></h1>
  <p class="onas-podtytul">Z nami każdy maluch rozbłyśnie jak <span>słońce</span></p>
  <p class="onas-hero-sub">Szkoła pływania powstała z pasji do wody i pracy z dziećmi. Uczymy od 6. miesiąca życia do 10. roku — bezpiecznie, z uśmiechem i bez pośpiechu, w weekendy na basenie przy ul. Ostrowskiego 3 na wrocławskim Grabiszynie.</p>
</div>

<!-- CYTAT -->
<div class="onas-cytat">
  <p class="onas-cytat-tekst">„Dziecko uczy się najlepiej, gdy czuje się <span>bezpiecznie i szczęśliwie.</span> Dlatego na zajęciach nie ma pośpiechu ani presji — jest radość, ruch i wsparcie."</p>
  <p class="onas-cytat-autor">Filozofia Solen Swim</p>
</div>

<!-- GŁÓWNA TREŚĆ -->
<div class="onas-main">

  <div class="onas-grid">

    <!-- LEWA -->
    <div>
      <span class="onas-sekcja-eyebrow">Kim jesteśmy</span>
      <h2 class="onas-sekcja-title">Uczymy pływać z uśmiechem</h2>
      <p class="onas-tekst">
        W Solen Swim wierzymy, że nauka pływania to coś więcej niż technika — to radość, zabawa i zaufanie. Tworzymy przyjazne zajęcia dla dzieci już od 6. miesiąca życia, w kameralnej atmosferze i pod okiem doświadczonych instruktorów.
      </p>
      <p class="onas-tekst">
        Naszym celem jest, by każde dziecko czuło się bezpiecznie i pokochało wodę od pierwszego kontaktu — od pierwszych plusków po pewne ruchy w wodzie.
      </p>
      <p class="onas-tekst">
        Nasza metodyka opiera się na nauce przez zabawę: ćwiczenia mają formę gier i zadań, dzięki którym dzieci oswajają się z wodą naturalnie, krok po kroku. Bezpieczeństwo jest zawsze na pierwszym miejscu — kameralne grupy do 8 dzieci pozwalają instruktorowi widzieć każdego malucha przez całe zajęcia i reagować na jego potrzeby.
      </p>
      <div class="onas-divider"></div>
      <p class="onas-tekst">
        Każde dziecko uczy się we własnym tempie. Zajęcia odbywają się w weekendy — w soboty i niedziele przedpołudniami — więc łatwo wpisują się w rodzinny plan tygodnia. Prowadzimy też lekcje indywidualne, również dla dorosłych, na basenie przy ul. Kamiennogórskiej 16. Wychodzimy z basenu z uśmiechem — i to jest dla nas najważniejsze.
      </p>
    </div>

    <!-- PRAWA -->
    <div>
      <span class="onas-sekcja-eyebrow">Dlaczego Solen Swim?</span>
      <h2 class="onas-sekcja-title">Co nas wyróżnia</h2>
      <ul class="onas-lista">
        <li><span class="onas-lista-dot"></span>Doświadczeni instruktorzy z pasją do nauki dzieci</li>
        <li><span class="onas-lista-dot"></span>Małe, kameralne grupy — max. 8 dzieci</li>
        <li><span class="onas-lista-dot"></span>Basen dostosowany do najmłodszych — odpowiednia temperatura i głębokość</li>
        <li><span class="onas-lista-dot"></span>Rodzinna, przyjazna atmosfera bez presji i pośpiechu</li>
        <li><span class="onas-lista-dot"></span>Zajęcia połączone z zabawą — nauka przez ruch i radość</li>
        <li><span class="onas-lista-dot"></span>Indywidualne podejście do każdego dziecka</li>
      </ul>
    </div>

  </div>

  <!-- ZAŁOŻYCIELKA -->
  <div class="onas-zalozycielka">
    <div class="onas-zal-foto" aria-hidden="true">KF</div>
    <!-- TODO: właścicielka — dodać zdjęcie Kamili + listę konkretnych certyfikatów/uprawnień (np. instruktor pływania, ratownik) -->
    <div class="onas-zal-tresc">
      <span class="onas-sekcja-eyebrow">Poznaj założycielkę</span>
      <h2 class="onas-sekcja-title">Kamila Falkowska</h2>
      <p class="onas-zal-rola">Założycielka i instruktorka Solen Swim</p>
      <p class="onas-tekst">
        Solen Swim to autorska szkoła pływania Kamili Falkowskiej — instruktorki, która na basenie czuje się jak w domu i tę radość z wody przekazuje dzieciom. To ona zbudowała filozofię szkoły: uczyć przez zabawę, bez presji i w małych grupach, w których każde dziecko ma czas i uwagę instruktora.
      </p>
      <p class="onas-tekst">
        Na zajęciach Kamila i zespół instruktorów stawiają na indywidualne podejście — od pierwszego oswajania niemowlaka z wodą po szlifowanie techniki u starszych dzieci. Chcesz porozmawiać o swoim dziecku przed zapisem? <a href="/kontakt/" class="onas-zal-link">Zadzwoń — chętnie doradzimy</a>.
      </p>
    </div>
  </div>

  <!-- KARTY WARTOŚCI -->
  <div class="onas-wartosci">
    <div class="onas-karta">
      <span class="onas-karta-ikona">🏊</span>
      <p class="onas-karta-tytul">Od 6. miesiąca życia</p>
      <p class="onas-karta-opis">Przyjmujemy najmłodszych — zajęcia niemowlęce z rodzicem</p>
    </div>
    <div class="onas-karta">
      <span class="onas-karta-ikona">👨‍🏫</span>
      <p class="onas-karta-tytul">Doświadczeni instruktorzy</p>
      <p class="onas-karta-opis">Certyfikowani specjaliści z pasją do pracy z dziećmi</p>
    </div>
    <div class="onas-karta">
      <span class="onas-karta-ikona">👪</span>
      <p class="onas-karta-tytul">Małe grupy</p>
      <p class="onas-karta-opis">Kameralna atmosfera, max. 8 dzieci w grupie</p>
    </div>
    <div class="onas-karta">
      <span class="onas-karta-ikona">☀️</span>
      <p class="onas-karta-tytul">Nauka przez zabawę</p>
      <p class="onas-karta-opis">Każde dziecko uczy się we własnym tempie i z uśmiechem</p>
    </div>
  </div>

  <!-- BANNER DOLNY -->
  <div class="onas-banner">
    <div class="onas-banner-tekst">
      <span class="onas-banner-eyebrow">Dołącz do nas</span>
      <p class="onas-banner-title">Zacznij pływać z Solen Swim!</p>
      <p class="onas-banner-sub">Wrocław · ul. Ostrowskiego 3 · Grabiszyn · bezpłatny parking</p>
    </div>
    <span class="onas-banner-badge">swim with the sun</span>
  </div>

</div>
</Base>

<style is:global>
* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  background: #FFF9F6;
  font-family: 'Space Mono', monospace;
  color: #293434;
}

/* ─── HERO SEKCJI ─── */
.onas-hero {
  background: #293434;
  padding: 80px 6%;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.onas-hero::before {
  content: '';
  position: absolute;
  width: 400px; height: 400px;
  border-radius: 50%;
  background: rgba(182,222,221,0.08);
  top: -150px; right: -100px;
}

.onas-hero::after {
  content: '';
  position: absolute;
  width: 250px; height: 250px;
  border-radius: 50%;
  background: rgba(255,131,87,0.07);
  bottom: -80px; left: -60px;
}

.onas-eyebrow {
  font-size: 10px;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: #B6DEDD;
  margin-bottom: 20px;
  display: block;
}

.onas-title {
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: clamp(32px, 6vw, 64px);
  line-height: 1.1;
  color: #FFF9F6;
  margin-bottom: 24px;
}

.onas-title span {
  color: #FF8357;
}

.onas-podtytul {
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: clamp(15px, 2.4vw, 20px);
  color: #B6DEDD;
  margin-bottom: 18px;
}

.onas-podtytul span {
  color: #FF8357;
}

.onas-hero-sub {
  font-size: 14px;
  color: #B6DEDD;
  letter-spacing: 1px;
  line-height: 1.8;
  max-width: 560px;
  margin: 0 auto;
  opacity: 0.85;
}

/* ─── CYTAT / MOTTO ─── */
.onas-cytat {
  background: #B6DEDD;
  padding: 56px 6%;
  text-align: center;
}

.onas-cytat-tekst {
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: clamp(18px, 3vw, 28px);
  color: #293434;
  line-height: 1.5;
  max-width: 700px;
  margin: 0 auto 16px;
}

.onas-cytat-tekst span {
  color: #FF8357;
}

.onas-cytat-autor {
  font-size: 11px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #293434;
  opacity: 0.55;
}

/* ─── GŁÓWNA TREŚĆ ─── */
.onas-main {
  padding: 80px 6%;
  max-width: 1200px;
  margin: 0 auto;
}

.onas-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: start;
  margin-bottom: 72px;
}

.onas-sekcja-eyebrow {
  font-size: 9px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #FF8357;
  margin-bottom: 14px;
  display: block;
}

.onas-sekcja-title {
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: 28px;
  color: #293434;
  margin-bottom: 24px;
  line-height: 1.25;
}

.onas-tekst {
  font-size: 14px;
  line-height: 1.95;
  color: #293434;
  opacity: 0.78;
  margin-bottom: 20px;
}

.onas-divider {
  width: 40px;
  height: 3px;
  background: #FF8357;
  border-radius: 2px;
  margin: 28px 0;
}

/* ─── LISTA WYRÓŻNIKÓW ─── */
.onas-lista {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.onas-lista li {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  font-size: 14px;
  line-height: 1.6;
  color: #293434;
}

.onas-lista-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #B6DEDD;
  flex-shrink: 0;
  margin-top: 6px;
}

/* ─── ZAŁOŻYCIELKA ─── */
.onas-zalozycielka {
  display: flex;
  align-items: center;
  gap: 48px;
  background: #FFF9F6;
  border-radius: 28px;
  box-shadow: 0 4px 32px rgba(41,52,52,0.08);
  padding: 48px;
  margin-bottom: 72px;
}

.onas-zal-foto {
  width: 180px;
  height: 180px;
  border-radius: 50%;
  background: #B6DEDD;
  color: #293434;
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: 52px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.onas-zal-tresc { flex: 1; }

.onas-zal-tresc .onas-sekcja-title { margin-bottom: 6px; }

.onas-zal-rola {
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #FF8357;
  margin-bottom: 20px;
  font-weight: 700;
}

.onas-zal-link {
  color: #FF8357;
  font-weight: 700;
  text-decoration: none;
}

.onas-zal-link:hover { text-decoration: underline; }

/* ─── KARTY WARTOŚCI ─── */
.onas-wartosci {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  margin-bottom: 72px;
}

.onas-karta {
  background: #FFF9F6;
  border-radius: 24px;
  padding: 32px 24px;
  box-shadow: 0 4px 32px rgba(41,52,52,0.08);
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}

.onas-karta:nth-child(1) { background: #B6DEDD; box-shadow: none; }
.onas-karta:nth-child(4) { background: #FF8357; box-shadow: none; }

.onas-karta-ikona {
  font-size: 32px;
  line-height: 1;
}

.onas-karta-tytul {
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: 15px;
  color: #293434;
  line-height: 1.3;
}

.onas-karta:nth-child(4) .onas-karta-tytul {
  color: #FFF9F6;
}

.onas-karta-opis {
  font-size: 12px;
  line-height: 1.6;
  color: #293434;
  opacity: 0.7;
}

.onas-karta:nth-child(4) .onas-karta-opis {
  color: #FFF9F6;
  opacity: 0.85;
}

/* ─── BANNER DOLNY ─── */
.onas-banner {
  background: #293434;
  border-radius: 28px;
  padding: 48px 48px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 32px;
}

.onas-banner-tekst {
  flex: 1;
}

.onas-banner-eyebrow {
  font-size: 9px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #B6DEDD;
  opacity: 0.7;
  margin-bottom: 12px;
  display: block;
}

.onas-banner-title {
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: 24px;
  color: #FFF9F6;
  line-height: 1.3;
  margin-bottom: 8px;
}

.onas-banner-sub {
  font-size: 13px;
  color: #B6DEDD;
  opacity: 0.75;
  line-height: 1.6;
}

.onas-banner-badge {
  background: #FF8357;
  color: #FFF9F6;
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 1px;
  padding: 16px 32px;
  border-radius: 100px;
  white-space: nowrap;
  flex-shrink: 0;
}

/* ── TABLET (≤760px) ── */
@media (max-width: 760px) {
  .onas-hero { padding: 60px 5%; }
  .onas-cytat { padding: 44px 5%; }
  .onas-main { padding: 56px 5%; }
  .onas-grid {
    grid-template-columns: 1fr;
    gap: 48px;
    margin-bottom: 52px;
  }
  .onas-wartosci {
    grid-template-columns: repeat(2, 1fr);
    margin-bottom: 52px;
  }
  .onas-zalozycielka {
    flex-direction: column;
    text-align: center;
    padding: 36px 28px;
    gap: 24px;
    margin-bottom: 52px;
  }
  .onas-zal-foto { width: 140px; height: 140px; font-size: 40px; }
  .onas-banner {
    flex-direction: column;
    align-items: flex-start;
    padding: 36px 32px;
  }
}

/* ── MOBILE (≤480px) ── */
@media (max-width: 480px) {
  .onas-hero { padding: 48px 4%; }
  .onas-hero-sub { font-size: 13px; }
  .onas-cytat { padding: 36px 4%; }
  .onas-cytat-tekst { font-size: 18px; }
  .onas-main { padding: 40px 4%; }
  .onas-sekcja-title { font-size: 22px; }
  .onas-tekst { font-size: 13px; }
  .onas-wartosci {
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 36px;
  }
  .onas-karta {
    padding: 22px 16px;
    border-radius: 18px;
    gap: 8px;
  }
  .onas-karta-ikona { font-size: 24px; }
  .onas-karta-tytul { font-size: 13px; }
  .onas-karta-opis { font-size: 11px; }
  .onas-banner {
    padding: 28px 22px;
    border-radius: 20px;
    gap: 20px;
  }
  .onas-banner-title { font-size: 20px; }
  .onas-banner-badge {
    width: 100%;
    text-align: center;
    padding: 14px 24px;
  }
}
</style>
