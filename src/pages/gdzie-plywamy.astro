---
import Base from '@/layouts/Base.astro';
const title = 'Gdzie pływamy — Basen Grabiszyn Wrocław | Solen Swim';
const description = 'Basen kryty na Grabiszynku, ul. Ostrowskiego 3 we Wrocławiu. 2 tory 12,5 m, głębokość 0,9–1,35 m, ogrzewana woda, darmowy parking. Idealne miejsce na naukę pływania dla dzieci.';
const path = '/gdzie-plywamy/';
const pageType = 'location' as const;
const breadcrumbs = [{ name: "Start", href: "/" }, { name: "Gdzie pływamy", href: "/gdzie-plywamy/" }];
---
<Base title={title} description={description} path={path} pageType={pageType} breadcrumbs={breadcrumbs}>
<!-- HERO -->
<div class="gp-hero">
  <span class="gp-eyebrow">Gdzie pływamy</span>
  <h1 class="gp-title">Znajdź nas<br>na <span>Grabiszynie</span></h1>
  <span class="gp-hero-adres">📍 ul. Aleksandra Ostrowskiego 3, Wrocław</span>
</div>

<!-- MOZAIKA ZDJEC -->
<div class="gp-mozaika">
  <div class="gp-foto">
    <img src="/assets/img-9c79488ad9a3.jpg" alt="Basen Solen Swim Wrocław">
  </div>
  <div class="gp-foto">
    <img src="/assets/img-f9a61ca66c17.jpg" alt="Basen kryty ul. Ostrowskiego Wrocław">
  </div>
  <div class="gp-foto">
    <img src="/assets/img-4b72bebcee47.jpg" alt="Zajęcia pływania dla dzieci Wrocław">
  </div>
</div>

<!-- MAIN -->
<div class="gp-main">

  <div class="gp-grid">

    <!-- INFO -->
    <div>
      <span class="gp-sekcja-eyebrow">O obiekcie</span>
      <h2 class="gp-sekcja-title">Basen stworzony<br>dla dzieci</h2>
      <div class="gp-info-lista">
        <div class="gp-info-item">
          <div class="gp-info-ikona">📍</div>
          <div>
            <span class="gp-info-label">Adres</span>
            <p class="gp-info-wartosc">ul. Aleksandra Ostrowskiego 3</p>
            <span class="gp-info-sub">Wrocław · dzielnica Grabiszyn</span>
          </div>
        </div>
        <div class="gp-info-item">
          <div class="gp-info-ikona">🏊</div>
          <div>
            <span class="gp-info-label">Obiekt</span>
            <p class="gp-info-wartosc">Baseny kryte</p>
            <span class="gp-info-sub">Woda podgrzewana · głębokość dostosowana do dzieci</span>
          </div>
        </div>
        <div class="gp-info-item">
          <div class="gp-info-ikona coral">🅿️</div>
          <div>
            <span class="gp-info-label">Parking</span>
            <p class="gp-info-wartosc">Bezpłatny parking</p>
            <span class="gp-info-sub">Bezpośrednio przy obiekcie</span>
          </div>
        </div>
        <a class="gp-info-item" href="tel:+48505912389" target="_blank">
          <div class="gp-info-ikona coral">📞</div>
          <div>
            <span class="gp-info-label">Kontakt</span>
            <p class="gp-info-wartosc">505 912 389</p>
            <span class="gp-info-sub">793 790 711</span>
          </div>
        </a>
      </div>
    </div>

    <!-- DOJAZD -->
    <div>
      <span class="gp-sekcja-eyebrow">Jak dojechać</span>
      <h2 class="gp-sekcja-title">Dojazd<br>i orientacja</h2>
      <ul class="gp-dojazd-lista">
        <li class="gp-dojazd-item">
          <div class="gp-dojazd-num">🚗</div>
          <div class="gp-dojazd-tekst">
            <p class="gp-dojazd-tytul">Samochodem</p>
            <p class="gp-dojazd-opis">Bezpłatny parking bezpośrednio przy obiekcie. Wjazd od ul. Ostrowskiego.</p>
          </div>
        </li>
        <li class="gp-dojazd-item">
          <div class="gp-dojazd-num">🚌</div>
          <div class="gp-dojazd-tekst">
            <p class="gp-dojazd-tytul">Komunikacją miejską</p>
            <p class="gp-dojazd-opis">Przystanek w pobliżu ul. Ostrowskiego — linie MPK w kierunku Grabiszyna.</p>
          </div>
        </li>
        <li class="gp-dojazd-item">
          <div class="gp-dojazd-num">🚲</div>
          <div class="gp-dojazd-tekst">
            <p class="gp-dojazd-tytul">Rowerem</p>
            <p class="gp-dojazd-opis">Dobra infrastruktura rowerowa w okolicy Grabiszyna.</p>
          </div>
        </li>
      </ul>
    </div>

  </div>

  <!-- HARMONOGRAM -->
  <div class="gp-harmonogram">
    <span class="gp-harm-eyebrow">Kiedy pływamy</span>
    <p class="gp-harm-title">Harmonogram zajęć</p>
    <div class="gp-harm-grid">
      <div class="gp-harm-karta">
        <span class="gp-harm-dzien">Czwartek</span>
        <p class="gp-harm-kurs">Niemowlęta · Nauka od podstaw</p>
        <p class="gp-harm-godziny">15:30 – 18:30</p>
      </div>
      <div class="gp-harm-karta">
        <span class="gp-harm-dzien">Sobota</span>
        <p class="gp-harm-kurs">Wszystkie kursy</p>
        <p class="gp-harm-godziny">9:00 – 15:00</p>
      </div>
      <div class="gp-harm-karta">
        <span class="gp-harm-dzien">Niedziela</span>
        <p class="gp-harm-kurs">Niemowlęta i dzieci do lat 4</p>
        <p class="gp-harm-godziny">10:00 – 12:00</p>
      </div>
    </div>
  </div>

</div>
</Base>

<style is:global>
* { margin: 0; padding: 0; box-sizing: border-box; }

/* Blokada auto-linkowania przez iOS/Android */
a[x-apple-data-detectors] {
  color: inherit !important;
  text-decoration: none !important;
  pointer-events: none;
}

body {
  background: #FFF9F6;
  font-family: 'Space Mono', monospace;
  color: #293434;
}

/* HERO */
.gp-hero {
  background: #B6DEDD;
  padding: 72px 6%;
  position: relative;
  overflow: hidden;
}

.gp-hero::after {
  content: '';
  position: absolute;
  width: 360px; height: 360px;
  border-radius: 50%;
  background: rgba(255,131,87,0.10);
  bottom: -120px; right: -80px;
  pointer-events: none;
}

.gp-eyebrow {
  font-size: 10px;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: #293434;
  opacity: 0.55;
  margin-bottom: 16px;
  display: block;
}

.gp-title {
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: clamp(32px, 6vw, 60px);
  color: #293434;
  line-height: 1.1;
  margin-bottom: 20px;
}

.gp-title span { color: #FF8357; }

.gp-hero-adres {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: #293434;
  color: #FFF9F6;
  font-size: 13px;
  padding: 10px 20px;
  border-radius: 100px;
  letter-spacing: 1px;
}

/* MOZAIKA ZDJEC */
.gp-mozaika {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  grid-template-rows: 280px 280px;
  gap: 6px;
  max-height: 566px;
}

.gp-foto {
  overflow: hidden;
  position: relative;
}

.gp-foto img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.5s ease;
}

.gp-foto:hover img {
  transform: scale(1.04);
}

/* zdjecie 1 zajmuje cala lewa kolumne */
.gp-foto:first-child {
  grid-row: 1 / 3;
}

/* MAIN */
.gp-main {
  padding: 72px 6%;
  max-width: 1200px;
  margin: 0 auto;
}

.gp-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  margin-bottom: 56px;
  align-items: start;
}

.gp-sekcja-eyebrow {
  font-size: 9px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #FF8357;
  margin-bottom: 12px;
  display: block;
}

.gp-sekcja-title {
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: 24px;
  color: #293434;
  margin-bottom: 28px;
  line-height: 1.3;
}

/* INFO KARTY */
.gp-info-lista {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.gp-info-item {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  padding: 18px 20px;
  background: #FFF9F6;
  border-radius: 16px;
  box-shadow: 0 2px 20px rgba(41,52,52,0.07);
  transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
}

/* Klikalna wersja karty (anchor z tel:) */
a.gp-info-item {
  text-decoration: none;
  color: #293434;
  cursor: pointer;
}
a.gp-info-item .gp-info-wartosc,
a.gp-info-item .gp-info-sub,
a.gp-info-item .gp-info-label {
  color: #293434;
}
a.gp-info-item:hover {
  background: rgba(255,131,87,0.12);
  box-shadow: 0 4px 28px rgba(255,131,87,0.18);
  transform: translateY(-2px);
}

.gp-info-ikona {
  width: 42px;
  height: 42px;
  border-radius: 12px;
  background: rgba(182,222,221,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
}

.gp-info-ikona.coral { background: rgba(255,131,87,0.15); }

.gp-info-label {
  font-size: 9px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #293434;
  opacity: 0.5;
  display: block;
  margin-bottom: 3px;
}

.gp-info-wartosc {
  font-size: 14px;
  color: #293434;
  line-height: 1.5;
  font-weight: 700;
}

.tel-link {
  color: inherit;
  text-decoration: none;
  cursor: pointer;
}

.gp-info-sub {
  font-size: 12px;
  color: #293434;
  opacity: 0.6;
  margin-top: 2px;
  display: block;
}

/* DOJAZD */
.gp-dojazd-lista {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.gp-dojazd-item {
  display: flex;
  align-items: flex-start;
  gap: 16px;
}

.gp-dojazd-num {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #FF8357;
  color: #FFF9F6;
  font-size: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.gp-dojazd-tekst { padding-top: 4px; }

.gp-dojazd-tytul {
  font-size: 13px;
  font-weight: 700;
  color: #293434;
  margin-bottom: 4px;
}

.gp-dojazd-opis {
  font-size: 12px;
  color: #293434;
  opacity: 0.65;
  line-height: 1.6;
}

/* HARMONOGRAM */
.gp-harmonogram {
  background: #293434;
  border-radius: 28px;
  padding: 48px;
}

.gp-harm-eyebrow {
  font-size: 9px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #B6DEDD;
  opacity: 0.7;
  display: block;
  margin-bottom: 8px;
}

.gp-harm-title {
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: 22px;
  color: #FFF9F6;
  margin-bottom: 32px;
}

.gp-harm-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

.gp-harm-karta {
  background: rgba(255,249,246,0.06);
  border-radius: 16px;
  padding: 22px 18px;
  border: 1px solid rgba(182,222,221,0.15);
}

.gp-harm-dzien {
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #B6DEDD;
  margin-bottom: 10px;
  display: block;
}

.gp-harm-kurs {
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: 13px;
  color: #FFF9F6;
  margin-bottom: 8px;
  line-height: 1.3;
}

.gp-harm-godziny {
  font-size: 13px;
  color: #FF8357;
  letter-spacing: 1px;
  font-weight: 700;
}

/* TABLET */
@media (max-width: 760px) {
  .gp-hero { padding: 56px 5%; }
  .gp-mozaika {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 220px 220px;
    max-height: none;
  }
  .gp-foto:first-child { grid-row: auto; }
  .gp-main { padding: 52px 5%; }
  .gp-grid { grid-template-columns: 1fr; gap: 44px; margin-bottom: 44px; }
  .gp-harmonogram { padding: 36px 28px; }
  .gp-harm-grid { grid-template-columns: 1fr 1fr; }
}

/* MOBILE */
@media (max-width: 480px) {
  .gp-hero { padding: 44px 4%; }
  .gp-mozaika {
    grid-template-columns: 1fr;
    grid-template-rows: 220px 200px 200px;
    gap: 4px;
    max-height: none;
  }
  .gp-foto:first-child { grid-row: auto; }
  .gp-main { padding: 40px 4%; }
  .gp-sekcja-title { font-size: 20px; }
  .gp-info-item { padding: 14px 16px; }
  .gp-harmonogram { padding: 28px 20px; border-radius: 20px; }
  .gp-harm-grid { grid-template-columns: 1fr; gap: 10px; }
}
</style>
