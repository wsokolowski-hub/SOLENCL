---
import Base from '@/layouts/Base.astro';
import { site } from '@/data/site';
const title = 'Basen dla dzieci Grabiszyn Wrocław — weekendy | Solen Swim';
const description = 'Basen dla dzieci na Grabiszynie we Wrocławiu — zajęcia w weekendy. 2 tory po 12,5 m, głębokość 0,9–1,35 m, podgrzewana woda i bezpłatny parking.';
const path = '/gdzie-plywamy/';
const pageType = 'location' as const;
const breadcrumbs = [{ name: "Start", href: "/" }, { name: "Gdzie pływamy", href: "/gdzie-plywamy/" }];
---
<Base title={title} description={description} path={path} pageType={pageType} breadcrumbs={breadcrumbs}>
<!-- HERO -->
<div class="gp-hero">
  <span class="gp-eyebrow">Gdzie pływamy</span>
  <h1 class="gp-title">Basen dla dzieci<br>na <span>Grabiszynie</span><span class="gp-title-sub">Znajdź nas we Wrocławiu — pływamy w każdy weekend</span></h1>
  <span class="gp-hero-adres">📍 {site.address.street}, {site.address.postal} {site.address.city}</span>
</div>

<!-- MOZAIKA ZDJEC -->
<div class="gp-mozaika">
  <div class="gp-foto">
    <img src="/assets/img-9c79488ad9a3.webp" alt="Basen Solen Swim Wrocław" width="800" height="535" loading="lazy">
  </div>
  <div class="gp-foto">
    <img src="/assets/img-f9a61ca66c17.webp" alt="Basen kryty ul. Ostrowskiego Wrocław" width="800" height="535" loading="lazy">
  </div>
  <div class="gp-foto">
    <img src="/assets/img-4b72bebcee47.webp" alt="Zajęcia pływania dla dzieci Wrocław" width="800" height="464" loading="lazy">
  </div>
</div>

<!-- MAIN -->
<div class="gp-main">

  <div class="gp-grid">

    <!-- INFO -->
    <div>
      <span class="gp-sekcja-eyebrow">O obiekcie</span>
      <h2 class="gp-sekcja-title">Basen stworzony<br>dla dzieci</h2>
      <div class="gp-info-lista">
        <div class="gp-info-item">
          <div class="gp-info-ikona">📍</div>
          <div>
            <span class="gp-info-label">Adres</span>
            <p class="gp-info-wartosc">{site.address.street}</p>
            <span class="gp-info-sub">{site.address.postal} {site.address.city} · dzielnica Grabiszyn</span>
          </div>
        </div>
        <div class="gp-info-item">
          <div class="gp-info-ikona">🏊</div>
          <div>
            <span class="gp-info-label">Obiekt</span>
            <p class="gp-info-wartosc">Baseny kryte</p>
            <span class="gp-info-sub">Woda podgrzewana · głębokość dostosowana do dzieci</span>
          </div>
        </div>
        <div class="gp-info-item">
          <div class="gp-info-ikona coral">🅿️</div>
          <div>
            <span class="gp-info-label">Parking</span>
            <p class="gp-info-wartosc">Bezpłatny parking</p>
            <span class="gp-info-sub">Bezpośrednio przy obiekcie</span>
          </div>
        </div>
        <a class="gp-info-item" href="tel:+48505912389">
          <div class="gp-info-ikona coral">📞</div>
          <div>
            <span class="gp-info-label">Kontakt</span>
            <p class="gp-info-wartosc">505 912 389</p>
            <span class="gp-info-sub">793 790 711</span>
          </div>
        </a>
      </div>
    </div>

    <!-- DOJAZD -->
    <div>
      <span class="gp-sekcja-eyebrow">Jak dojechać</span>
      <h2 class="gp-sekcja-title">Dojazd<br>i orientacja</h2>
      <ul class="gp-dojazd-lista">
        <li class="gp-dojazd-item">
          <div class="gp-dojazd-num">🚗</div>
          <div class="gp-dojazd-tekst">
            <p class="gp-dojazd-tytul">Samochodem</p>
            <p class="gp-dojazd-opis">Bezpłatny parking bezpośrednio przy obiekcie — w weekendowe poranki bez problemu znajdziecie miejsce. Wjazd od ul. Ostrowskiego.</p>
          </div>
        </li>
        <li class="gp-dojazd-item">
          <div class="gp-dojazd-num">🚌</div>
          <div class="gp-dojazd-tekst">
            <p class="gp-dojazd-tytul">Komunikacją miejską</p>
            <p class="gp-dojazd-opis">Najbliższe przystanki to „Ostrowskiego” i „Grabiszyńska” w ciągu ul. Grabiszyńskiej — dojedziecie tramwajem lub autobusem MPK Wrocław, a stamtąd czeka Was krótki spacer.</p>
            <!-- TODO: właściciel — uzupełnić numery linii MPK -->
          </div>
        </li>
        <li class="gp-dojazd-item">
          <div class="gp-dojazd-num">🚲</div>
          <div class="gp-dojazd-tekst">
            <p class="gp-dojazd-tytul">Rowerem</p>
            <p class="gp-dojazd-opis">Dobra infrastruktura rowerowa w okolicy Grabiszyna.</p>
          </div>
        </li>
      </ul>
    </div>

  </div>

  <!-- PARAMETRY BASENU -->
  <section class="gp-parametry">
    <span class="gp-sekcja-eyebrow">Nasz basen w liczbach</span>
    <h2 class="gp-sekcja-title">Warunki idealne<br>do nauki pływania</h2>
    <p class="gp-parametry-intro">Nasz basen na Grabiszynie został pomyślany z myślą o najmłodszych pływakach. Zajęcia prowadzimy w kameralnych grupach do 8 dzieci, dla maluchów od 6. miesiąca życia do 10 lat — każdy znajdzie tu swoją głębokość, dosłownie i w przenośni.</p>
    <div class="gp-param-grid">
      <div class="gp-param-karta">
        <span class="gp-param-liczba">2 × 12,5 m</span>
        <p class="gp-param-opis">Dwa tory po 12,5 metra — wystarczająco dużo miejsca na naukę, bez tłoku znanego z dużych pływalni.</p>
      </div>
      <div class="gp-param-karta">
        <span class="gp-param-liczba">0,9–1,35 m</span>
        <p class="gp-param-opis">Głębokość idealna do nauki — dzieci czują dno pod stopami, a rodzice mają spokojną głowę.</p>
      </div>
      <div class="gp-param-karta">
        <span class="gp-param-liczba">Ciepła woda</span>
        <p class="gp-param-opis">Woda podgrzewana do temperatury komfortowej dla dzieci — nawet niemowlęta pływają z uśmiechem.</p>
      </div>
      <div class="gp-param-karta">
        <span class="gp-param-liczba">Basen kryty</span>
        <p class="gp-param-opis">Pływamy pod dachem, więc zajęcia odbywają się przez cały rok — niezależnie od pogody za oknem.</p>
      </div>
    </div>
  </section>

  <!-- HARMONOGRAM -->
  <div class="gp-harmonogram">
    <span class="gp-harm-eyebrow">Kiedy pływamy</span>
    <p class="gp-harm-title">Harmonogram zajęć — tylko w weekendy</p>
    <div class="gp-harm-grid">
      {site.poolHours.map((slot) => (
        <div class="gp-harm-karta">
          <span class="gp-harm-dzien">{slot.day}</span>
          <p class="gp-harm-kurs">Wszystkie kursy</p>
          <p class="gp-harm-godziny">{slot.value}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- OKOLICE -->
  <section class="gp-okolice">
    <span class="gp-sekcja-eyebrow">Blisko Was</span>
    <h2 class="gp-sekcja-title">Dojeżdżają do nas rodzice<br>z całej okolicy</h2>
    <p class="gp-okolice-opis">Grabiszyn leży tuż przy dużych osiedlach mieszkaniowych zachodniego i południowego Wrocławia, więc dojazd na zajęcia zajmuje dosłownie chwilę. A ponieważ pływamy wyłącznie w weekendy, na basen bez pośpiechu zdążą także pracujący rodzice — sobotni lub niedzielny poranek w wodzie to świetny początek rodzinnego dnia.</p>
    <ul class="gp-okolice-chips">
      <li class="gp-chip"><strong>Grabiszynek</strong> — tuż obok, kilka minut spacerem</li>
      <li class="gp-chip"><strong>Gajowice</strong> — ok. 5 minut samochodem</li>
      <li class="gp-chip"><strong>Muchobór Mały</strong> — 5–10 minut samochodem</li>
      <li class="gp-chip"><strong>Oporów</strong> — 5–10 minut samochodem</li>
      <li class="gp-chip"><strong>Krzyki</strong> — ok. 10 minut samochodem</li>
      <li class="gp-chip"><strong>Popowice</strong> — ok. 10 minut samochodem</li>
    </ul>
  </section>

  <!-- MAPA -->
  <section class="gp-mapa">
    <span class="gp-sekcja-eyebrow">Mapa dojazdu</span>
    <h2 class="gp-sekcja-title">Zobacz nas na mapie</h2>
    <div class="gp-mapa-ramka">
      <iframe
        src={site.maps.embedUrl}
        title={`Mapa dojazdu — Solen Swim, ${site.address.street}, ${site.address.postal} ${site.address.city}`}
        loading="lazy"
        allowfullscreen
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>
    <div class="gp-mapa-btns">
      <a class="gp-btn gp-btn-coral" href={site.maps.directionsUrl} target="_blank" rel="noopener">Wyznacz trasę</a>
      <a class="gp-btn gp-btn-outline" href={site.reviews.googleProfileUrl} target="_blank" rel="noopener">Zobacz wizytówkę w Google</a>
    </div>
    <p class="gp-mapa-nota">Zajęcia indywidualne prowadzimy również na drugim obiekcie przy ul. Kamiennogórskiej 16, 54-034 Wrocław.</p>
  </section>

</div>
</Base>

<style is:global>
* { margin: 0; padding: 0; box-sizing: border-box; }

/* Blokada auto-linkowania przez iOS/Android */
a[x-apple-data-detectors] {
  color: inherit !important;
  text-decoration: none !important;
  pointer-events: none;
}

body {
  background: #FFF9F6;
  font-family: 'Space Mono', monospace;
  color: #293434;
}

/* HERO */
.gp-hero {
  background: #B6DEDD;
  padding: 72px 6%;
  position: relative;
  overflow: hidden;
}

.gp-hero::after {
  content: '';
  position: absolute;
  width: 360px; height: 360px;
  border-radius: 50%;
  background: rgba(255,131,87,0.10);
  bottom: -120px; right: -80px;
  pointer-events: none;
}

.gp-eyebrow {
  font-size: 10px;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: #293434;
  opacity: 0.55;
  margin-bottom: 16px;
  display: block;
}

.gp-title {
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: clamp(32px, 6vw, 60px);
  color: #293434;
  line-height: 1.1;
  margin-bottom: 20px;
}

.gp-title span { color: #FF8357; }

.gp-hero-adres {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: #293434;
  color: #FFF9F6;
  font-size: 13px;
  padding: 10px 20px;
  border-radius: 100px;
  letter-spacing: 1px;
}

/* MOZAIKA ZDJEC */
.gp-mozaika {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  grid-template-rows: 280px 280px;
  gap: 6px;
  max-height: 566px;
}

.gp-foto {
  overflow: hidden;
  position: relative;
}

.gp-foto img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.5s ease;
}

.gp-foto:hover img {
  transform: scale(1.04);
}

/* zdjecie 1 zajmuje cala lewa kolumne */
.gp-foto:first-child {
  grid-row: 1 / 3;
}

/* MAIN */
.gp-main {
  padding: 72px 6%;
  max-width: 1200px;
  margin: 0 auto;
}

.gp-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  margin-bottom: 56px;
  align-items: start;
}

.gp-sekcja-eyebrow {
  font-size: 9px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #FF8357;
  margin-bottom: 12px;
  display: block;
}

.gp-sekcja-title {
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: 24px;
  color: #293434;
  margin-bottom: 28px;
  line-height: 1.3;
}

/* INFO KARTY */
.gp-info-lista {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.gp-info-item {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  padding: 18px 20px;
  background: #FFF9F6;
  border-radius: 16px;
  box-shadow: 0 2px 20px rgba(41,52,52,0.07);
  transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
}

/* Klikalna wersja karty (anchor z tel:) */
a.gp-info-item {
  text-decoration: none;
  color: #293434;
  cursor: pointer;
}
a.gp-info-item .gp-info-wartosc,
a.gp-info-item .gp-info-sub,
a.gp-info-item .gp-info-label {
  color: #293434;
}
a.gp-info-item:hover {
  background: rgba(255,131,87,0.12);
  box-shadow: 0 4px 28px rgba(255,131,87,0.18);
  transform: translateY(-2px);
}

.gp-info-ikona {
  width: 42px;
  height: 42px;
  border-radius: 12px;
  background: rgba(182,222,221,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
}

.gp-info-ikona.coral { background: rgba(255,131,87,0.15); }

.gp-info-label {
  font-size: 9px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #293434;
  opacity: 0.5;
  display: block;
  margin-bottom: 3px;
}

.gp-info-wartosc {
  font-size: 14px;
  color: #293434;
  line-height: 1.5;
  font-weight: 700;
}

.tel-link {
  color: inherit;
  text-decoration: none;
  cursor: pointer;
}

.gp-info-sub {
  font-size: 12px;
  color: #293434;
  opacity: 0.6;
  margin-top: 2px;
  display: block;
}

/* DOJAZD */
.gp-dojazd-lista {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.gp-dojazd-item {
  display: flex;
  align-items: flex-start;
  gap: 16px;
}

.gp-dojazd-num {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #FF8357;
  color: #FFF9F6;
  font-size: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.gp-dojazd-tekst { padding-top: 4px; }

.gp-dojazd-tytul {
  font-size: 13px;
  font-weight: 700;
  color: #293434;
  margin-bottom: 4px;
}

.gp-dojazd-opis {
  font-size: 12px;
  color: #293434;
  opacity: 0.65;
  line-height: 1.6;
}

/* HARMONOGRAM */
.gp-harmonogram {
  background: #293434;
  border-radius: 28px;
  padding: 48px;
}

.gp-harm-eyebrow {
  font-size: 9px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #B6DEDD;
  opacity: 0.7;
  display: block;
  margin-bottom: 8px;
}

.gp-harm-title {
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: 22px;
  color: #FFF9F6;
  margin-bottom: 32px;
}

.gp-harm-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

.gp-harm-karta {
  background: rgba(255,249,246,0.06);
  border-radius: 16px;
  padding: 22px 18px;
  border: 1px solid rgba(182,222,221,0.15);
}

.gp-harm-dzien {
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #B6DEDD;
  margin-bottom: 10px;
  display: block;
}

.gp-harm-kurs {
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: 13px;
  color: #FFF9F6;
  margin-bottom: 8px;
  line-height: 1.3;
}

.gp-harm-godziny {
  font-family: 'Comfortaa', sans-serif;
  font-size: 14px;
  color: #FF8357;
  letter-spacing: 1px;
  font-weight: 700;
}

/* PODTYTUŁ W H1 */
.gp-title-sub {
  display: block;
  font-family: 'Space Mono', monospace;
  font-weight: 400;
  font-size: clamp(12px, 1.6vw, 15px);
  letter-spacing: 1px;
  color: #293434 !important;
  opacity: 0.65;
  margin-top: 14px;
  text-transform: none;
}

/* PARAMETRY BASENU */
.gp-parametry {
  margin: 56px 0;
}

.gp-parametry-intro {
  font-size: 13px;
  line-height: 1.8;
  color: #293434;
  opacity: 0.7;
  max-width: 680px;
  margin-bottom: 32px;
}

.gp-param-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}

.gp-param-karta {
  background: #FFF9F6;
  border-radius: 20px;
  padding: 26px 22px;
  box-shadow: 0 2px 20px rgba(41,52,52,0.07);
  border-top: 4px solid #B6DEDD;
}

.gp-param-karta:nth-child(2) { border-top-color: #FF8357; }
.gp-param-karta:nth-child(3) { border-top-color: #FFB094; }
.gp-param-karta:nth-child(4) { border-top-color: #86C6C4; }

.gp-param-liczba {
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: 22px;
  color: #FF8357;
  display: block;
  margin-bottom: 10px;
}

.gp-param-opis {
  font-size: 12px;
  line-height: 1.65;
  color: #293434;
  opacity: 0.7;
}

/* OKOLICE / DZIELNICE */
.gp-okolice {
  margin: 56px 0;
}

.gp-okolice-opis {
  font-size: 13px;
  line-height: 1.8;
  color: #293434;
  opacity: 0.7;
  max-width: 680px;
  margin-bottom: 28px;
}

.gp-okolice-chips {
  list-style: none;
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  padding: 0;
}

.gp-chip {
  background: rgba(182,222,221,0.35);
  border-radius: 100px;
  padding: 10px 20px;
  font-size: 12px;
  color: #293434;
  line-height: 1.4;
}

.gp-chip strong {
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
}

/* MAPA */
.gp-mapa {
  margin-top: 56px;
}

.gp-mapa-ramka {
  border-radius: 24px;
  overflow: hidden;
  box-shadow: 0 4px 32px rgba(41,52,52,0.10);
  margin-bottom: 22px;
}

.gp-mapa-ramka iframe {
  display: block;
  width: 100%;
  height: 420px;
  border: 0;
}

.gp-mapa-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  margin-bottom: 18px;
}

.gp-btn {
  display: inline-block;
  font-family: 'Comfortaa', sans-serif;
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 0.5px;
  padding: 14px 32px;
  border-radius: 100px;
  text-decoration: none;
  transition: transform 0.2s, box-shadow 0.2s;
}

.gp-btn-coral {
  background: #FF8357;
  color: #FFF9F6;
  box-shadow: 0 6px 24px rgba(255,131,87,0.30);
}

.gp-btn-coral:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 30px rgba(255,131,87,0.40);
  color: #FFF9F6;
}

.gp-btn-outline {
  background: transparent;
  color: #293434;
  border: 2px solid #B6DEDD;
}

.gp-btn-outline:hover {
  background: rgba(182,222,221,0.25);
  color: #293434;
}

.gp-mapa-nota {
  font-size: 12px;
  color: #293434;
  opacity: 0.6;
  line-height: 1.6;
}

/* TABLET */
@media (max-width: 760px) {
  .gp-param-grid { grid-template-columns: 1fr 1fr; }
  .gp-mapa-ramka iframe { height: 340px; }
  .gp-hero { padding: 56px 5%; }
  .gp-mozaika {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 220px 220px;
    max-height: none;
  }
  .gp-foto:first-child { grid-row: auto; }
  .gp-main { padding: 52px 5%; }
  .gp-grid { grid-template-columns: 1fr; gap: 44px; margin-bottom: 44px; }
  .gp-harmonogram { padding: 36px 28px; }
  .gp-harm-grid { grid-template-columns: 1fr 1fr; }
}

/* MOBILE */
@media (max-width: 480px) {
  .gp-hero { padding: 44px 4%; }
  .gp-mozaika {
    grid-template-columns: 1fr;
    grid-template-rows: 220px 200px 200px;
    gap: 4px;
    max-height: none;
  }
  .gp-foto:first-child { grid-row: auto; }
  .gp-main { padding: 40px 4%; }
  .gp-sekcja-title { font-size: 20px; }
  .gp-info-item { padding: 14px 16px; }
  .gp-harmonogram { padding: 28px 20px; border-radius: 20px; }
  .gp-harm-grid { grid-template-columns: 1fr; gap: 10px; }
  .gp-param-grid { grid-template-columns: 1fr; }
  .gp-parametry, .gp-okolice { margin: 40px 0; }
  .gp-mapa { margin-top: 40px; }
  .gp-mapa-ramka iframe { height: 280px; }
  .gp-btn { width: 100%; text-align: center; }
