/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://featurable.com; style-src 'self' 'unsafe-inline' https://featurable.com; img-src 'self' data: https:; font-src 'self' https://featurable.com; connect-src 'self' https://api.web3forms.com https://featurable.com https://api.featurable.com; frame-src https://www.google.com https://maps.google.com; frame-ancestors 'self'; object-src 'none'; base-uri 'self'; form-action 'self' https://api.web3forms.com; upgrade-insecure-requests

# Hashowane bundle Astro — bezpieczny roczny cache
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Fonty self-hosted — stabilne nazwy z sufiksem, zmieniają się rzadko
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Obrazy w /assets/ NIE są hashowane — po podmianie pliku użytkownik
# musi zobaczyć nową wersję, stąd tydzień + rewalidacja.
/assets/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/favicon.ico
  Cache-Control: public, max-age=604800

/favicon-32.png
  Cache-Control: public, max-age=604800

/apple-touch-icon.png
  Cache-Control: public, max-age=604800
